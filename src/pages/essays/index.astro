---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'; // 核心图片处理组件

// 获取所有杂文并按日期倒序排列
const allEssays = await getCollection('essays');
const sortedEssays = allEssays.sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date) : new Date(0);
    const dateB = b.data.date ? new Date(b.data.date) : new Date(0);
    return dateB.getTime() - dateA.getTime();
});
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>杂文集 | Rui & Ruibeet</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+SC:wght@300;500&family=ZCOOL+XiaoWei&family=Cinzel:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* 页面背景与基础设置 */
        body { background-color: #DF9225; color: black; margin: 0; font-family: 'Noto Serif SC', serif; }
        
        header { padding: 80px 20px 40px; text-align: center; }
        h1 { font-family: 'ZCOOL XiaoWei', serif; font-size: clamp(40px, 8vw, 64px); margin: 0; letter-spacing: 0.1em; }
        
        /* 按照你的要求改为 BLOGS */
        .subtitle { font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.5em; margin-top: 15px; opacity: 0.8; }

        /* 列表容器 */
        .essay-list { max-width: 1000px; margin: 40px auto; padding: 0 20px; display: flex; flex-direction: column; gap: 50px; }
        
        /* 文章卡片 */
        .essay-card { 
            display: flex; 
            background: white; 
            border: 2px solid black; 
            box-shadow: 15px 15px 0px black; 
            text-decoration: none; 
            color: black;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .essay-card:hover { transform: translate(-5px, -5px); box-shadow: 20px 20px 0px black; }

        /* 图片显示区域 */
        .card-image-wrapper { 
            width: 350px; 
            min-width: 350px; 
            height: 240px; 
            border-right: 2px solid black; 
            overflow: hidden; 
            background: #f0f0f0; 
        }
        .card-image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
        .essay-card:hover .card-image { transform: scale(1.05); }

        /* 文字描述区域 */
        .card-content { padding: 40px; flex-grow: 1; display: flex; flex-direction: column; justify-content: center; }
        .date { font-family: 'Playfair Display', serif; font-size: 14px; color: #DF9225; margin-bottom: 10px; font-style: italic; font-weight: bold; }
        .essay-title { font-family: 'ZCOOL XiaoWei', serif; font-size: 32px; margin-bottom: 15px; line-height: 1.3; }
        .essay-desc { font-size: 16px; opacity: 0.7; line-height: 1.8; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

        /* 移动端适配 */
        @media (max-width: 850px) {
            .essay-card { flex-direction: column; }
            .card-image-wrapper { width: 100%; border-right: none; border-bottom: 2px solid black; height: 250px; }
            h1 { font-size: 48px; }
        }
    </style>
</head>
<body>

    <header>
        <h1>杂文集</h1>
        <p class="subtitle">BLOGS</p>
    </header>

    <main class="essay-list">
        {sortedEssays.map((essay) => (
            <a href={`/essays/${essay.slug}`} class="essay-card">
                <div class="card-image-wrapper">
                    {essay.data.image ? (
                        /* ✨ 修复：使用 Astro 的 Image 组件 */
                        <Image 
                            src={essay.data.image} 
                            alt={essay.data.title} 
                            class="card-image"
                            width={700}
                            height={480}
                        />
                    ) : (
                        <div style="display:flex; align-items:center; justify-content:center; height:100%; font-family:Cinzel; opacity:0.2;">RUI ARCHIVE</div>
                    )}
                </div>
                <div class="card-content">
                    <div class="date">
                        {essay.data.date?.toLocaleDateString('zh-CN', {year: 'numeric', month: 'long', day: 'numeric'})}
                    </div>
                    <h2 class="essay-title">{essay.data.title}</h2>
                    <p class="essay-desc">{essay.data.description}</p>
                </div>
            </a>
        ))}
    </main>

    <footer style="padding: 120px 0; text-align: center; opacity: 0.3; font-size: 10px; letter-spacing: 0.5em;">
        EST. 2026 / RUI & RUIBEET ARCHIVE
    </footer>

</body>
</html>
