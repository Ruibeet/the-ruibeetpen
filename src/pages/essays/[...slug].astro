---
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+SC:wght@300;500&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        /* 全局背景色 */
        body { 
            background-color: #DF9225; 
            color: white; 
            margin: 0; 
            font-family: 'Noto Serif SC', serif; 
        }

        /* 文章白底容器 */
        main { 
            max-width: 750px; 
            margin: 0 auto; 
            background: white; 
            color: #1a1a1a; 
            padding: 80px 40px; 
            min-height: 100vh; 
            border-left: 2px solid black; 
            border-right: 2px solid black;
            box-sizing: border-box;
        }

        /* 返回按钮 */
        .back-nav {
            margin-bottom: 40px;
            font-family: 'Playfair Display', serif;
            font-size: 12px;
            letter-spacing: 0.2em;
        }
        .back-nav a { color: #1a1a1a; text-decoration: none; border-bottom: 1px solid black; }

        /* 大标题 */
        h1 { 
            font-family: 'ZCOOL XiaoWei', serif; 
            font-size: clamp(32px, 5vw, 56px); 
            text-align: center; 
            margin-bottom: 40px; 
            line-height: 1.2;
        }

        /* 正文排版 */
        .content { 
            font-size: 18px; 
            line-height: 2.1; 
            text-align: justify; 
        }

        .content :global(p) { margin-bottom: 2.2em; }

        /* 核心修复：文章内图片控制 */
        .content :global(img) {
            display: block;
            max-width: 100%; /* 关键：图片永远不会超出白框 */
            height: auto;
            margin: 3.5rem auto 1rem;
            border: 1px solid rgba(0,0,0,0.1);
            padding: 8px;
            background: #fcfcfc;
        }

        /* 核心修复：小标题样式 */
        .content :global(h3) {
            font-family: 'ZCOOL XiaoWei', serif;
            font-size: 26px;
            margin: 4rem 0 1.5rem 0;
            border-bottom: 1.5px solid black;
            display: inline-block;
            padding-bottom: 5px;
        }

        /* 核心修复：图注样式 (斜体字) */
        .content :global(p > em) {
            display: block;
            text-align: center;
            font-size: 14px;
            color: #666;
            margin-top: -0.5rem;
            margin-bottom: 3.5rem;
            line-height: 1.6;
            font-family: 'Noto Serif SC', serif;
        }

        /* 模拟 Paris Review 引用块 */
        .content :global(blockquote) {
            border-left: 3px solid #DF9225;
            padding-left: 30px;
            margin: 3em 0;
            font-style: italic;
            opacity: 0.8;
        }

        /* 评论区样式调整 */
        #waline { 
            margin-top: 100px; 
            padding-top: 50px; 
            border-top: 1px solid #eee; 
            color: #1a1a1a; /* 确保评论区文字在白底上可见 */
        }
    </style>
</head>
<body>
    <main>
        <nav class="back-nav">
            <a href="/essays">← BACK TO MANUSCRIPTS</a>
        </nav>

        <div style="text-align: center; text-transform: uppercase; letter-spacing: 0.4em; margin-bottom: 20px; opacity: 0.5; font-size: 10px;">
            {entry.data.category} / {entry.data.date?.toLocaleDateString()}
        </div>

        <h1>{entry.data.title}</h1>
        
        {entry.data.image && (
            <img src={entry.data.image} style="width: 100%; height: 400px; object-fit: cover; margin-bottom: 60px; border: 2.5px solid black; box-shadow: 10px 10px 0px rgba(0,0,0,0.1);" />
        )}
        
        <div class="content">
            <Content />
        </div>

        <div id="waline"></div>
    </main>

    <script>
        import { init } from 'https://unpkg.com/@waline/client@v2/dist/waline.mjs';
        import 'https://unpkg.com/@waline/client@v2/dist/waline.css';
        
        const walineElement = document.getElementById('waline');
        if (walineElement) {
            init({
                el: '#waline',
                serverURL: 'https://your-waline-server.vercel.app', // 记得替换成你自己的地址
                lang: 'zh-CN',
                dark: false,
            });
        }
    </script>
</body>
</html>
