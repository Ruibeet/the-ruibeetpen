---
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+SC:wght@300;500&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
    /* 全局背景与基础设置 */
    body { background-color: #DF9225; color: white; margin: 0; font-family: 'Noto Serif SC', serif; }
    
    /* 文章容器：增加 overflow-x: hidden 确保万一溢出也不会产生横向滚动条 */
    main { 
        max-width: 750px; 
        margin: 0 auto; 
        background: white; 
        color: #1a1a1a; 
        padding: 80px 40px; 
        min-height: 100vh; 
        border-left: 2px solid black; 
        border-right: 2px solid black;
        box-sizing: border-box;
        overflow-wrap: break-word; /* 确保长单词不撑破容器 */
    }

    .back-nav { margin-bottom: 40px; font-family: 'Playfair Display', serif; font-size: 12px; letter-spacing: 0.2em; }
    .back-nav a { color: #1a1a1a; text-decoration: none; border-bottom: 1px solid black; }

    h1 { font-family: 'ZCOOL XiaoWei', serif; font-size: clamp(32px, 5vw, 56px); text-align: center; margin-bottom: 40px; line-height: 1.2; }

    .content { font-size: 18px; line-height: 2.1; text-align: justify; }
    .content :global(p) { margin-bottom: 2.2em; }

    /* --- 核心修复：强制约束图片 --- */
    /* 1. 针对所有在 .content 内部的图片进行深度强制约束 */
    .content :global(img) {
        display: block !important;
        /* 使用 max-inline-size 代替 max-width 以获得更高优先级 */
        max-width: 100% !important; 
        height: auto !important;
        margin: 3.5rem auto !important;
        border: 1.5px solid black !important;
        padding: 8px !important;
        background: #fcfcfc !important;
        box-sizing: border-box !important; /* 确保 padding 不会增加图片的实际宽度 */
    }

    /* 2. 针对可能包裹图片的 p 标签进行宽度重置 */
    .content :global(p:has(img)) {
        max-width: 100% !important;
        display: block !important;
    }

    /* 小标题与图注样式保持优雅 */
    .content :global(h3) {
        font-family: 'ZCOOL XiaoWei', serif;
        font-size: 26px;
        margin: 4rem 0 1.5rem 0;
        border-bottom: 1.5px solid black;
        display: inline-block;
        padding-bottom: 5px;
    }

    .content :global(p > em) {
        display: block !important;
        text-align: center !important;
        font-size: 14px !important;
        color: #666 !important;
        margin-top: -2.5rem !important; /* 让图注紧贴图片底部 */
        margin-bottom: 4rem !important;
        font-family: 'Noto Serif SC', serif;
    }

    #waline { margin-top: 100px; padding-top: 50px; border-top: 1px solid #eee; color: #1a1a1a; }
</style>
</head>
<body>
    <main>
        <nav class="back-nav">
            <a href="/essays">← BACK TO MANUSCRIPTS</a>
        </nav>

        <div style="text-align: center; text-transform: uppercase; letter-spacing: 0.4em; margin-bottom: 20px; opacity: 0.5; font-size: 10px;">
            {entry.data.category} / {entry.data.date?.toLocaleDateString()}
        </div>

        <h1>{entry.data.title}</h1>

        

        {entry.data.image && (

            <div class="main-cover-wrapper">

                <img src={entry.data.image} alt={entry.data.title} class="main-cover-img" />

            </div>

        )}

        

        <div class="content">

            <Content />

        </div>



        <div id="waline"></div>

    <script>
        import { init } from 'https://unpkg.com/@waline/client@v2/dist/waline.mjs';
        import 'https://unpkg.com/@waline/client@v2/dist/waline.css';
        
        const walineElement = document.getElementById('waline');
        if (walineElement) {
            init({
                el: '#waline',
                serverURL: 'https://your-waline-server.vercel.app', // 记得替换成你自己的地址
                lang: 'zh-CN',
                dark: false,
            });
        }
    </script>
</body>
</html>
