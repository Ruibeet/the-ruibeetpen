---
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html>
<head>
    <meta charset="utf-8" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+SC:wght@300;500&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        body { background-color: #DF9225; color: white; margin: 0; font-family: 'Noto Serif SC', serif; }
        main { max-width: 750px; margin: 0 auto; background: white; color: #1a1a1a; padding: 80px 60px; min-height: 100vh; border-left: 2px solid black; border-right: 2px solid black; }
        h1 { font-family: 'ZCOOL XiaoWei', serif; font-size: 56px; text-align: center; margin-bottom: 40px; }
        .content { font-size: 18px; line-height: 2.2; text-align: justify; }
        .content p { margin-bottom: 2em; }
        /* 模拟 Paris Review 英文排版 */
        .content :global(em) { font-family: 'Playfair Display', serif; font-style: italic; }
    </style>
</head>
<body>
    <main>
        <div style="text-align: center; text-transform: uppercase; letter-spacing: 0.3em; margin-bottom: 20px; opacity: 0.5;">{entry.data.category}</div>
        <h1>{entry.data.title}</h1>
        {entry.data.image && <img src={entry.data.image} style="width: 100%; margin-bottom: 60px; border: 1px solid black;" />}
        
        <div class="content">
            <Content />
        </div>

        <div id="waline" style="margin-top: 100px; padding-top: 50px; border-top: 1px solid #eee;"></div>
    </main>

    <script>
        import { init } from 'https://unpkg.com/@waline/client@v2/dist/waline.mjs';
        import 'https://unpkg.com/@waline/client@v2/dist/waline.css';
        init({
          el: '#waline',
          serverURL: 'https://your-waline-server.vercel.app', // 这里需要你部署一个免费的评论后台
          lang: 'zh-CN',
          visitor: true,
        });
    </script>
</body>
</html>
