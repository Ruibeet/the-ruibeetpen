---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <title>{entry.data.title} | THE ARCHIVE</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Noto Serif SC', serif; line-height: 2; }
        article h3 { font-size: 1.5rem; font-weight: bold; margin-top: 2rem; margin-bottom: 1rem; }
        article p { margin-bottom: 1.5rem; color: #1a1a1a; }
        article blockquote { border-left: 4px solid #A7C9D5; padding-left: 1.5rem; font-style: italic; color: #4a4a4a; margin: 2rem 0; }
    </style>
</head>
<body class="bg-white text-black antialiased">
    <nav class="border-b border-black py-6 px-6 md:px-16 flex justify-between items-center uppercase font-bold text-xs tracking-widest">
        <a href="/">← BACK TO ARCHIVE</a>
        <span class="text-[#0A9C49]">{entry.data.category}</span>
    </nav>

    <main class="max-w-3xl mx-auto px-6 py-20">
        <header class="mb-16">
            <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-8">{entry.data.title}</h1>
            <div class="flex gap-4 text-gray-400 text-sm tracking-widest uppercase">
                <span>{entry.data.date.toLocaleDateString()}</span>
                <span>/</span>
                <span>RU BEET</span>
            </div>
        </header>

        <article class="text-xl">
            <Content />
        </article>

        <footer class="mt-20 pt-10 border-t border-gray-100">
            <div class="bg-[#EEC43E]/10 p-8 border-2 border-dashed border-[#EEC43E]">
                <p class="text-sm font-bold mb-2">喜欢这篇文章吗？</p>
                <p class="text-xs text-gray-600">欢迎在 Patreon 支持我的创作，或订阅我的双语邮件列表。</p>
            </div>
        </footer>
    </main>
</body>
</html>
