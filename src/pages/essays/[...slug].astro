---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'; // ✨ 关键：引入 Astro 官方图片组件

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+SC:wght@300;500&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
    /* 全局背景与基础设置 */
    body { background-color: #DF9225; color: white; margin: 0; font-family: 'Noto Serif SC', serif; }
    
    /* 文章容器 */
    main { 
        max-width: 750px; 
        margin: 0 auto; 
        background: white; 
        color: #1a1a1a; 
        padding: 80px 40px; 
        min-height: 100vh; 
        border-left: 2px solid black; 
        border-right: 2px solid black;
        box-sizing: border-box;
        overflow-wrap: break-word;
    }

    .back-nav { margin-bottom: 40px; font-family: 'Playfair Display', serif; font-size: 12px; letter-spacing: 0.2em; }
    .back-nav a { color: #1a1a1a; text-decoration: none; border-bottom: 1px solid black; }

    h1 { font-family: 'ZCOOL XiaoWei', serif; font-size: clamp(32px, 5vw, 56px); text-align: center; margin-bottom: 40px; line-height: 1.2; color: black; }

    .content { font-size: 18px; line-height: 2.1; text-align: justify; }
    .content :global(p) { margin-bottom: 2.2em; }

    /* --- 核心修复：封面图锁定 --- */
    .main-cover-wrapper {
        width: 100%;
        max-width: 100%;
        margin: 0 auto 60px auto;
        box-sizing: border-box;
    }

    .main-cover-img {
        display: block;
        width: 100% !important;
        max-width: 100% !important;
        height: auto !important;
        border: 2px solid black;
        box-shadow: 10px 10px 0px rgba(0,0,0,0.1);
        box-sizing: border-box;
    }

    /* --- 正文内容图片样式 --- */
    .content :global(img) {
        display: block !important;
        max-width: 100% !important; 
        height: auto !important;
        margin: 3.5rem auto !important;
        border: 1.5px solid black !important;
        padding: 8px !important;
        background: #fcfcfc !important;
        box-sizing: border-box !important;
    }

    .content :global(p:has(img)) {
        max-width: 100% !important;
        display: block !important;
    }

    .content :global(h3) {
        font-family: 'ZCOOL XiaoWei', serif;
        font-size: 26px;
        margin: 4rem 0 1.5rem 0;
        border-bottom: 1.5px solid black;
        display: inline-block;
        padding-bottom: 5px;
    }

    .content :global(p > em) {
        display: block !important;
        text-align: center !important;
        font-size: 14px !important;
        color: #666 !important;
        margin-top: -2.5rem !important; 
        margin-bottom: 4rem !important;
        font-family: 'Noto Serif SC', serif;
    }

    #waline { margin-top: 100px; padding-top: 50px; border-top: 1px solid #eee; color: #1a1a1a; }
</style>
</head>
<body>
    <main>
        <nav class="back-nav">
            <a href="/essays">← BACK TO MANUSCRIPTS</a>
        </nav>

        <div style="text-align: center; text-transform: uppercase; letter-spacing: 0.4em; margin-bottom: 20px; opacity: 0.5; font-size: 10px;">
            {entry.data.category} / {entry.data.date?.toLocaleDateString('zh-CN')}
        </div>

        <h1>{entry.data.title}</h1>

        {/* ✨ 核心修复：改用 <Image /> 组件处理封面 */}
        {entry.data.image && (
            <div class="main-cover-wrapper">
                <Image 
                    src={entry.data.image} 
                    alt={entry.data.title} 
                    class="main-cover-img"
                    width={1200}
                    height={800}
                />
            </div>
        )}

        <div class="content">
            <Content />
        </div>

        <div id="waline"></div>
    </main>

    <script>
        import { init } from 'https://unpkg.com/@waline/client@v2/dist/waline.mjs';
        import 'https://unpkg.com/@waline/client@v2/dist/waline.css';
        
        const walineElement = document.getElementById('waline');
        if (walineElement) {
            init({
                el: '#waline',
                serverURL: 'https://your-waline-server.vercel.app', 
                lang: 'zh-CN',
                dark: false,
            });
        }
    </script>
</body>
</html>
