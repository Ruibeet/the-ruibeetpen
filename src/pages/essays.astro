---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays');
// 按日期排序
const sortedEssays = allEssays.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const pageTitle = "Essays / 杂文";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <title>{pageTitle} | Rui & Ruibeet</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;900&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        body { background-color: #DF9225; margin: 0; font-family: 'Noto Serif SC', serif; color: white; }
        nav { padding: 40px; }
        nav a { color: white; text-decoration: none; font-family: 'Playfair Display'; border-bottom: 1px solid white; font-size: 12px; letter-spacing: 0.2em; }
        
        main { max-width: 800px; margin: 0 auto; padding: 100px 20px; }
        .list-header { text-align: center; margin-bottom: 100px; }
        .list-header h1 { font-family: 'ZCOOL XiaoWei', serif; font-size: 64px; color: black; margin: 0; }
        
        .essay-item { 
            display: flex; gap: 40px; margin-bottom: 80px; 
            background: white; color: black; border: 2px solid black; 
            padding: 30px; box-shadow: 10px 10px 0px black;
            transition: transform 0.3s;
        }
        .essay-item:hover { transform: translate(-5px, -5px); box-shadow: 15px 15px 0px black; }
        .essay-img { width: 200px; height: 150px; object-fit: cover; border: 1px solid black; }
        .essay-info { flex: 1; }
        .essay-info h2 { font-family: 'ZCOOL XiaoWei', serif; font-size: 28px; margin: 0 0 15px 0; }
        .essay-info a { text-decoration: none; color: black; }
        .essay-info p { font-style: italic; opacity: 0.7; font-size: 15px; }
    </style>
</head>
<body>
    <nav>
        <a href="/">← BACK TO ARCHIVE</a>
    </nav>

    <main>
        <div class="list-header">
            <h1>杂文集</h1>
            <p style="text-transform: uppercase; letter-spacing: 0.5em; margin-top: 10px; color: black; font-weight: 700;">Manuscripts & Observations</p>
        </div>

        <div class="essay-list">
            {sortedEssays.map(essay => (
                <div class="essay-item">
                    {essay.data.image && <img src={essay.data.image} class="essay-img" />}
                    <div class="essay-info">
                        <span style="font-size: 10px; font-weight: 900; letter-spacing: 0.2em; color: #DF9225;">{essay.data.date.toLocaleDateString()}</span>
                        <a href={`/essays/${essay.slug}`}>
                            <h2>{essay.data.title}</h2>
                        </a>
                        <p>{essay.data.description}</p>
                    </div>
                </div>
            ))}
        </div>
    </main>
</body>
</html>
