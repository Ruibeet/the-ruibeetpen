---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'; // 引入 Image 组件处理本地图片

// 核心逻辑：只获取 category 为 "100-people" 的文章
const posts = await getCollection('field', ({ data }) => data.category === '100-people');

// 排序：按日期倒序
const sortedPosts = posts.sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>百人 | 100 People Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --theme-yellow: #F3DE16; 
            --border-color: #000000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body { 
            background-color: var(--theme-yellow); 
            font-family: 'Noto Serif SC', serif; 
            color: black; 
            line-height: 1.6;
        }

        /* ✨ 新增：返回主页按钮样式 */
        .back-home {
            position: absolute;
            top: 40px;
            left: 40px;
        }
        .back-home a {
            font-family: 'Cinzel', serif;
            font-size: 12px;
            text-decoration: none;
            color: black;
            letter-spacing: 2px;
            opacity: 0.5;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
        }
        .back-home a:hover {
            opacity: 1;
            transform: translateX(-5px);
        }

        .header { 
            text-align: center; 
            padding: 120px 20px 60px; 
            border-bottom: 2.5px solid var(--border-color); 
        }

        .header h1 { 
            font-family: 'ZCOOL XiaoWei', serif; 
            font-size: clamp(60px, 10vw, 90px); 
            margin: 0;
            letter-spacing: 12px;
            color: black;
        }

        .header .en-sub { 
            font-family: 'Cinzel', serif; 
            font-size: 13px; 
            font-weight: 400;
            letter-spacing: 6px; 
            text-transform: uppercase; 
            opacity: 0.7;
            margin-top: 25px;
            display: block;
        }

        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
            gap: 50px; 
            padding: 80px 40px; 
            max-width: 1300px; 
            margin: 0 auto;
        }

        .card { 
            background: white; 
            border: 2.5px solid var(--border-color); 
            box-shadow: 12px 12px 0px var(--border-color); 
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            text-decoration: none; 
            color: black;
            display: flex;
            flex-direction: column;
        }

        .card:hover { 
            transform: translate(-6px, -6px); 
            box-shadow: 20px 20px 0px var(--border-color); 
        }

        .card-image-box {
            width: 100%;
            height: 350px;
            overflow: hidden;
            border-bottom: 2.5px solid var(--border-color);
            background: #eee;
        }

        /* 统一图片样式 */
        .card-image-box :global(img) {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(30%);
            transition: 0.5s;
        }

        .card:hover .card-image-box :global(img) {
            filter: grayscale(0%);
            transform: scale(1.05);
        }

        .card-content { padding: 30px; }
        .card-content h2 { font-family: 'ZCOOL XiaoWei', serif; font-size: 28px; margin-bottom: 15px; }
        .card-content .summary { font-size: 14px; opacity: 0.8; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-align: justify; }

        .card-footer {
            margin-top: auto;
            padding: 0 30px 30px;
            font-family: 'Cinzel', serif;
            font-size: 10px;
            letter-spacing: 2px;
            opacity: 0.4;
        }

        @media (max-width: 768px) {
            .back-home { top: 20px; left: 20px; }
            .grid { padding: 40px 20px; }
        }
    </style>
</head>
<body>

    <nav class="back-home">
        <a href="/">← HOME</a>
    </nav>

    <header class="header">
        <h1>百人</h1>
        <span class="en-sub">100 People / Profile</span>
    </header>

    <main class="grid">
        {sortedPosts.map(post => (
            <a href={`/field/${post.slug}`} class="card">
                <div class="card-image-box">
                    {post.data.image ? (
                        <Image 
                            src={post.data.image} 
                            alt={post.data.title}
                            width={600}
                            height={800}
                        />
                    ) : (
                        <div style="height: 100%; display: flex; align-items: center; justify-content: center; opacity: 0.2;">NO IMAGE</div>
                    )}
                </div>
                <div class="card-content">
                    <h2>{post.data.title}</h2>
                    <p class="summary">{post.data.summary}</p>
                </div>
                <div class="card-footer">
                    {post.data.location} / {new Date(post.data.date).getFullYear()}
                </div>
            </a>
        ))}
    </main>

    <footer style="padding: 100px 0; text-align: center; opacity: 0.3; font-family: 'Cinzel'; font-size: 10px; letter-spacing: 5px;">
        THE 100 PEOPLE PROJECT
    </footer>

</body>
</html>
