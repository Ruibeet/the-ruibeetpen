---
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const entries = await getCollection('field');
  return entries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <title>{entry.data.title}</title>
    <style>
        body { background-color: #F3DE16; padding: 60px 20px; line-height: 1.8; }
        article { max-width: 700px; margin: 0 auto; background: white; padding: 40px; border: 2px solid black; box-shadow: 10px 10px 0px black; }
    </style>
</head>
<body>
    <article>
        <h1>{entry.data.title}</h1>
        <hr />
        <Content />
    </article>
</body>
</html>
