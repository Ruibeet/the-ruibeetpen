---
import { getCollection } from 'astro:content';
const posts = await getCollection('field', ({ data }) => data.category === 'mountains');
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <style>
        body { background-color: #F3DE16; font-family: 'Noto Serif SC', serif; }
        .container { max-width: 1000px; margin: 0 auto; padding: 60px 20px; }
        .report-header { border-left: 8px solid black; padding-left: 20px; margin-bottom: 60px; }
        .report-header h1 { font-family: 'Playfair Display'; font-size: 60px; }
        
        .list { display: flex; flex-direction: column; gap: 40px; }
        .item { 
            display: grid; grid-template-columns: 350px 1fr; gap: 30px;
            background: rgba(255,255,255,0.5); padding: 30px; border: 1px solid black;
        }
        .item img { width: 100%; height: 200px; object-fit: cover; filter: grayscale(100%); }
        .item-text h2 { font-size: 30px; margin-top: 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="report-header">
            <h1>MOUNTAINS</h1>
            <p>FIELD REPORT / 纪实报告</p>
        </div>
        <div class="list">
            {posts.map(post => (
                <div class="item">
                    <img src={post.data.image || 'https://via.placeholder.com/400x300'} />
                    <div class="item-text">
                        <h2>{post.data.title}</h2>
                        <p>{post.data.summary}</p>
                        <a href={`/field/${post.slug}`} style="color: black; font-weight: bold;">READ REPORT →</a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</body>
</html>
