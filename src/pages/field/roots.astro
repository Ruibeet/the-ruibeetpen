---
import { getCollection } from 'astro:content';
const posts = await getCollection('field', ({ data }) => data.category === 'roots');
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <style>
        body { background-color: #F3DE16; font-family: 'Noto Serif SC', serif; }
        .roots-container { max-width: 800px; margin: 0 auto; padding: 80px 20px; text-align: center; }
        .intro { font-style: italic; opacity: 0.6; margin-bottom: 80px; }
        
        .post-entry { margin-bottom: 100px; }
        .post-entry h2 { font-family: 'ZCOOL XiaoWei'; font-size: 32px; margin-bottom: 20px; }
        .circle-img { width: 200px; height: 200px; border-radius: 50%; object-fit: cover; margin: 0 auto 30px; border: 2px solid white; }
        .excerpt { line-height: 2; letter-spacing: 1px; }
    </style>
</head>
<body>
    <div class="roots-container">
        <h1>ROOTS</h1>
        <p class="intro">家庭民族志与口述史：寻根之旅</p>
        
        {posts.map(post => (
            <div class="post-entry">
                <img src={post.data.image || 'https://via.placeholder.com/200x200'} class="circle-img" />
                <h2>{post.data.title}</h2>
                <p class="excerpt">"{post.data.summary}..."</p>
                <a href={`/field/${post.slug}`} style="color: black; text-decoration: none; border-bottom: 1px solid black;">继续阅读</a>
            </div>
        ))}
    </div>
</body>
</html>
