---
import { getCollection } from 'astro:content';

const title = "Life Fragments";
const subtitle = "Moments, Memories, and Miscellany";

// 1. 获取所有内容。注意：这里改成了 'field'，对应你的文件夹
const allLifePosts = await getCollection('field');

// 2. 排序并处理内容渲染
const sortedPosts = await Promise.all(
  allLifePosts.sort((a, b) => {
    const dateA = a.data.date instanceof Date ? a.data.date : new Date(a.data.date);
    const dateB = b.data.date instanceof Date ? b.data.date : new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  }).map(async (post) => {
    const { Content } = await post.render(); // 这一步是把 Markdown 变成网页内容
    return { ...post, Content };
  })
);

const isDev = import.meta.env.DEV; 
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rui</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg-color: #EEC43E; 
            --border-color: #000000; 
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: black; 
            line-height: 1.8;
        }
        .container { max-width: 900px; margin: 0 auto; padding: 60px 40px; }
        .page-header { margin-bottom: 60px; text-align: center; }
        .page-header h1 { font-family: 'Playfair Display'; font-size: clamp(40px, 8vw, 60px); color: black; }
        .page-header p { font-family: 'Cinzel'; letter-spacing: 4px; opacity: 0.7; font-size: 11px; margin-top: 15px; }
        .life-stream { display: flex; flex-direction: column; gap: 60px; }
        .life-post-card {
            background: white;
            border: 2.5px solid black;
            padding: 40px;
            box-shadow: 10px 10px 0px black;
            transition: 0.4s;
        }
        .post-meta { font-family: 'Cinzel'; font-size: 11px; opacity: 0.5; margin-bottom: 25px; letter-spacing: 2px; }
        .post-content { font-size: 15px; line-height: 2; opacity: 0.9; text-align: justify; }
        .post-content h2 { font-family: 'ZCOOL XiaoWei'; font-size: 28px; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <header class="page-header">
            <h1>{title}</h1>
            <p>{subtitle}</p>
        </header>

        <main class="life-stream">
            {sortedPosts.map(({ data, Content }) => (
                <article class="life-post-card">
                    <div class="post-meta">
                        {data.date ? new Date(data.date).toLocaleDateString() : ''} / {data.category}
                    </div>

                    <div class="post-content">
                        {data.title && (
                            <h2>{data.title}</h2>
                        )}
                        <Content />
                    </div>
                </article>
            ))}
        </main>

        <footer style="margin-top: 120px; text-align: center; opacity: 0.5; font-family: 'Cinzel'; font-size: 10px;">
            EST. 2026 / RUI & RUIBEET LIFE ARCHIVE
        </footer>
    </div>
</body>
</html>
