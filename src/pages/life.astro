---
import { getCollection } from 'astro:content';

// 获取 life 文件夹下的所有 md 文件
const lifePosts = await getCollection('life').catch(() => []);

// 按日期排序：将最新的碎碎念排在最前面
const sortedLife = lifePosts.sort((a, b) => {
  const dateA = a.data.date instanceof Date ? a.data.date : new Date(a.data.date);
  const dateB = b.data.date instanceof Date ? b.data.date : new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});

const title = "LIFE";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,700&family=Noto+Serif+SC:wght@300;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --life-orange: #EEC43E; /* 沿用你首页 Life 的目录色 */
            --border-color: #000000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body { 
            background-color: var(--life-orange); /* 全局背景变为橙色 */
            font-family: 'Noto Serif SC', serif; 
            color: #000; 
            line-height: 1.6;
        }

        .layout {
            display: grid;
            grid-template-columns: 1fr 300px;
            max-width: 1400px;
            margin: 0 auto;
            gap: 60px;
            padding: 80px 40px;
        }

        /* 标题：纯英文，拉大间距 */
        .page-title {
            grid-column: 1 / -1;
            font-family: 'Cinzel', serif;
            font-size: clamp(60px, 8vw, 100px);
            letter-spacing: 0.3em;
            text-align: left;
            margin-bottom: 60px;
            border-bottom: 3px solid var(--border-color);
            padding-bottom: 20px;
        }

        /* 瀑布流布局 */
        .waterfall {
            column-count: 2;
            column-gap: 30px;
        }

        /* 每一条内容的卡片 */
        .post-card {
            break-inside: avoid;
            margin-bottom: 30px;
            background: white; /* 卡片白底，在橙色背景上非常醒目 */
            border: 2.5px solid var(--border-color);
            box-shadow: 8px 8px 0px var(--border-color); /* 延续硬核阴影 */
            padding: 20px;
            transition: 0.3s;
        }

        .post-card:hover {
            transform: translate(-4px, -4px);
            box-shadow: 12px 12px 0px var(--border-color);
        }

        .post-card img {
            width: 100%;
            height: auto;
            border: 1px solid #eee;
            margin-bottom: 15px;
        }

        .post-card h3 { 
            font-family: 'Playfair Display', serif; 
            font-size: 22px; 
            margin-bottom: 10px;
