---
import { getCollection } from 'astro:content';

const lifePosts = await getCollection('life').catch(() => []);
const sortedLife = lifePosts.sort((a, b) => {
  const dateA = a.data.date instanceof Date ? a.data.date : new Date(a.data.date);
  const dateB = b.data.date instanceof Date ? b.data.date : new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LIFE | Rui's Stream</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,400&family=Noto+Serif+SC:wght@300;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* 使用 ID 选择器确保样式只作用于此页面，不污染首页 */
        #life-page-wrapper {
            --life-orange: #EEC43E; /* 你指定的主题橙 */
            --border-black: #000000;
            background-color: var(--life-orange);
            min-height: 100vh;
            font-family: 'Noto Serif SC', serif;
            margin: 0;
            padding: 0;
            color: #000;
        }

        .life-container {
            display: grid;
            grid-template-columns: 1fr 280px; /* 左侧流，右侧社交 */
            max-width: 1300px;
            margin: 0 auto;
            gap: 50px;
            padding: 100px 40px;
        }

        /* 2) Life 大标题居中 */
        .page-title {
            grid-column: 1 / -1;
            font-family: 'Cinzel', serif;
            font-size: clamp(60px, 10vw, 120px);
            letter-spacing: 0.4em; /* 保持网页整体的高呼吸感间距 */
            text-align: center; /* 居中 */
            margin-bottom: 80px;
            padding-bottom: 20px;
            border-bottom: 3px solid var(--border-black);
            font-weight: 700;
        }

        /* 瀑布流布局 */
        .waterfall {
            column-count: 2;
            column-gap: 30px;
        }

        .post-card {
            break-inside: avoid;
            margin-bottom: 30px;
            background: white;
            border: 2.5px solid var(--border-black);
            box-shadow: 10px 10px 0px var(--border-black); /* 统一网页的硬核阴影风格 */
            padding: 25px;
            transition: 0.3s ease;
        }

        .post-card:hover {
            transform: translate(-5px, -5px);
            box-shadow: 15px 15px 0px var(--border-black);
        }

        .post-card img {
            width: 100%;
            height: auto;
            border: 1px solid #eee;
            margin-bottom: 20px;
        }

        .post-card h3 { 
            font-family: 'Playfair Display', serif; 
            font-size: 24px; 
            margin-bottom: 12px;
            font-weight: 700;
        }

        .post-card .content p { 
            font-size: 15px; 
            line-height: 1.8; 
            color: #1a1a1a;
            text-align: justify;
        }

        .post-meta {
            margin-top: 20px;
            font-family: 'Cinzel', serif;
            font-size: 10px;
            letter-spacing: 2px;
            opacity: 0.5;
            display: block;
        }

        /* 右侧社交栏 */
        .sidebar {
            position: sticky;
            top: 40px;
            height: fit-content;
            padding: 20px 0;
        }

        .sidebar-label {
            font-family: 'Cinzel', serif;
            font-size: 11px;
            letter-spacing: 4px;
            margin-bottom: 40px;
            opacity: 0.6;
            text-transform: uppercase;
        }

        .social-link {
            display: flex;
            align-items: center;
            gap: 20px;
            text-decoration: none;
            color: black;
            font-family: 'Cinzel', serif;
            font-size: 13px;
            margin-bottom: 35px;
            transition: 0.3s;
            font-weight: 700;
        }

        .social-link i { font-size: 26px; }
        .social-link:hover { transform: translateX(8px); opacity: 0.7; }

        /* 移动端适配 */
        @media (max-width: 900px) {
            .life-container { grid-template-columns: 1fr; padding: 60px 20px; }
            .waterfall { column-count: 1; }
            .sidebar { position: static; border-top: 2px solid #000; padding-top: 40px; margin-top: 20px; }
            .page-title { font-size: 50px; letter-spacing: 0.2em; }
        }
    </style>
</head>
<body>

    <div id="life-page-wrapper">
        <div class="life-container">
            <h1 class="page-title">LIFE</h1>

            <main class="waterfall">
                {sortedLife.map(post => (
                    <div class="post-card">
                        {post.data.image && <img src={post.data.image} alt={post.data.title} />}
                        <h3>{post.data.title}</h3>
                        <div class="content">
                            <p>{post.body.substring(0, 150)}...</p>
                        </div>
                        <small class="post-meta">
                            {post.data.location && `${post.data.location} // `}
                            {post.data.date ? new Date(post.data.date).toLocaleDateString() : '2026'}
                        </small>
                    </div>
                ))}
            </main>

            <aside class="sidebar">
                <p class="sidebar-label">Stay Connected</p>
                
                <a href="https://instagram.com/你的账号" target="_blank" class="social-link">
                    <i class="fab fa-instagram"></i>
                    <span>Instagram</span>
                </a>

                <a href="https://linkedin.com/in/你的账号" target="_blank" class="social-link">
                    <i class="fab fa-linkedin"></i>
                    <span>LinkedIn</span>
                </a>

                <a href="你的Substack链接" target="_blank" class="social-link">
                    <i class="fas fa-envelope-open-text"></i>
                    <span>Substack</span>
                </a>
            </aside>
        </div>
    </div>

</body>
</html>
