---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays').catch(() => []);
const latestEssays = allEssays
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const title = "Rui & Ruibeet";
const subtitle = "She's got a lot to say before going to hell";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+SC:wght@200;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: #A7C9D4; 
            color: #1a1a1a; 
        }

        header { padding: 80px 20px 40px; text-align: center; }
        .main-title { 
            font-family: 'Playfair Display', serif; 
            font-size: clamp(40px, 8vw, 80px); 
            font-weight: 400; 
            letter-spacing: 0.02em;
        }
        .subtitle { 
            font-family: 'Cinzel', serif; 
            font-size: 10px; 
            letter-spacing: 0.4em; 
            text-transform: uppercase; 
            opacity: 0.5; 
            margin-top: 20px; 
        }

        /* 导航栏：双语色彩方块 */
        nav { 
            position: sticky; top: 0; z-index: 100; 
            padding: 0 40px;
            background: rgba(167, 201, 212, 0.9);
            backdrop-filter: blur(8px);
        }
        .nav-container { 
            display: flex; max-width: 900px; margin: 0 auto; 
            border: 2.5px solid black; 
            box-shadow: 8px 8px 0px black;
        }
        .nav-item { 
            flex: 1; padding: 15px 5px; text-align: center; 
            text-decoration: none; color: white !important; 
            border-right: 2.5px solid black; transition: 0.3s;
            display: flex; flex-direction: column; gap: 4px;
        }
        .nav-item:last-child { border-right: none; }
        .nav-item .cn { font-family: 'ZCOOL XiaoWei', serif; font-size: 16px; }
        .nav-item .en { font-family: 'Cinzel', serif; font-size: 9px; opacity: 0.8; }
        .nav-item:hover { background-color: white !important; }
        .nav-item:hover span { color: black !important; }

        /* 列表区：图文卡片 */
        .content-grid { max-width: 900px; margin: 60px auto; padding: 0 20px; }
        
        .essay-card { 
            background: white; border: 2.5px solid black; 
            margin-bottom: 50px;
            box-shadow: 10px 10px 0px black;
            display: flex; /* 改为横向排布或堆叠 */
            flex-direction: column;
            text-decoration: none; color: black;
            transition: 0.2s;
            overflow: hidden;
        }
        .essay-card:hover { transform: translate(-4px, -4px); box-shadow: 14px 14px 0px black; }
        
        /* 卡片图片预览 */
        .card-image {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-bottom: 2.5px solid black;
        }

        .card-text { padding: 40px; }
        .essay-date { font-family: 'Cinzel'; font-size: 10px; opacity: 0.4; letter-spacing: 0.2em; }
        .essay-title { font-family: 'ZCOOL XiaoWei', serif; font-size: 32px; margin: 15px 0; }
        .essay-desc { font-size: 15px; line-height: 1.8; opacity: 0.7; }

        /* 打赏区：红牛双语版 */
        .support-section { padding: 100px 20px; text-align: center; }
        .support-card { 
            display: inline-block; border: 3px solid black; padding: 60px 40px; 
            background: white; box-shadow: 12px 12px 0px #0A9C49; 
            max-width: 600px;
        }
        .support-card h4 { font-family: 'ZCOOL XiaoWei'; font-size: 32px; margin-bottom: 10px; }
        .support-card .en-sub { font-family: 'Playfair Display', serif; font-style: italic; opacity: 0.5; margin-bottom: 30px; display: block; }
        .support-text { margin-bottom: 30px; line-height: 1.8; }
        
        .patreon-btn { 
            display: inline-block; background: black; color: white; 
            text-decoration: none; padding: 20px 40px; font-weight: 700; 
            letter-spacing: 0.2em; text-transform: uppercase; font-size: 12px;
        }

        footer { padding: 80px 0; text-align: center; opacity: 0.3; font-size: 10px; letter-spacing: 0.5em; }
    </style>
</head>
<body>

    <header>
        <h1 class="main-title">{title}</h1>
        <p class="subtitle">{subtitle}</p>
    </header>

    <nav>
        <div class="nav-container">
            <a href="/" class="nav-item" style="background-color: #000000;">
                <span class="cn">首页</span><span class="en">Home</span>
            </a>
            <a href="/novel" class="nav-item" style="background-color: #0A9C49;">
                <span class="cn">小说</span><span class="en">Fiction</span>
            </a>
            <a href="/essays" class="nav-item" style="background-color: #DF9225;">
                <span class="cn">杂文</span><span class="en">Blogs</span>
            </a>
            <a href="/life" class="nav-item" style="background-color: #EEC43E; color: black !important;">
                <span class="cn">生活</span><span class="en">Life</span>
            </a>
            <a href="/field" class="nav-item" style="background-color: #F3DE16; color: black !important;">
                <span class="cn">田野</span><span class="en">Field</span>
            </a>
        </div>
    </nav>

    <main class="content-grid">
        {latestEssays.map((essay) => (
            <a href={`/essays/${essay.slug}`} class="essay-card">
                {essay.data.image && (
                    <img src={essay.data.image} alt={essay.data.title} class="card-image" />
                )}
                <div class="card-text">
                    <div class="essay-date">{essay.data.date.toLocaleDateString()} / {essay.data.category}</div>
                    <h2 class="essay-title">{essay.data.title}</h2>
                    <p class="essay-desc">{essay.data.description}</p>
                </div>
            </a>
        ))}
    </main>

    <section class="support-section">
        <div class="support-card">
            <h4>支持我的田野观察</h4>
            <span class="en-sub">Support my field observations</span>
            
            <div class="support-text">
                <p>如果你喜欢这些档案，欢迎请我喝杯咖啡（或红牛）。</p>
                <p style="font-size: 14px; opacity: 0.5;">If you enjoy these archives, feel free to buy me a coffee or a Red Bull.</p>
            </div>

            <a href="你的链接" class="patreon-btn">Sponsor a Red Bull</a>
        </div>
    </section>

    <footer>EST. 2026 / RUI & RUIBEET ARCHIVE</footer>

</body>
</html>
