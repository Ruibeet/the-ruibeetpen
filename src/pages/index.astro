---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays').catch(() => []);
const title = "Rui & Ruibeet";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | The Archive</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@200;600;900&family=Playfair+Display:ital,wght@0,900;1,900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Noto Serif SC', serif; background-color: #ffffff; }
        .paris-border { border-top: 1px solid black; border-bottom: 1px solid black; }
        .nav-item { transition: all 0.3s ease; }
        .nav-item:hover { background-color: white; color: black !important; }
        /* 强制正文居中排版 */
        .content-container { max-width: 750px; margin: 0 auto; }
    </style>
</head>
<body class="text-[#1a1a1a] antialiased">

    <header class="py-32 px-6">
        <div class="max-w-screen-xl mx-auto text-center">
            <h1 class="text-7xl md:text-[120px] font-black tracking-tighter mb-4 italic" style="font-family: 'Playfair Display', serif;">
                {title}
            </h1>
            <p class="font-sans text-[11px] tracking-[0.6em] uppercase opacity-40">Digital Field & Literary Archive</p>
        </div>
    </header>

    <nav class="sticky top-0 z-50 px-4 md:px-10">
        <div class="flex flex-wrap w-full border border-black overflow-hidden shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
            <a href="/" class="flex-1 min-w-[120px] text-center py-4 bg-black text-white text-[11px] font-bold uppercase tracking-widest nav-item">Home / 主页</a>
            <div class="flex-1 min-w-[120px] text-center py-4 bg-[#DF9225] text-white text-[11px] font-bold uppercase tracking-widest relative group cursor-pointer nav-item">
                Fiction / 小说
                <div class="absolute hidden group-hover:block top-full left-0 w-full bg-white border border-black text-black shadow-xl">
                    <a href="/novel/long" class="block py-3 hover:bg-[#F3DE16]">长篇</a>
                    <a href="/novel/short" class="block py-3 hover:bg-[#F3DE16]">短篇</a>
                </div>
            </div>
            <a href="/essays" class="flex-1 min-w-[120px] text-center py-4 bg-[#0A9C49] text-white text-[11px] font-bold uppercase tracking-widest nav-item">Essays / 杂文</a>
            <a href="/life" class="flex-1 min-w-[120px] text-center py-4 bg-[#A7C9D5] text-white text-[11px] font-bold uppercase tracking-widest nav-item">Life / 生活</a>
            <a href="/field" class="flex-1 min-w-[120px] text-center py-4 bg-[#EEC43E] text-black text-[11px] font-bold uppercase tracking-widest nav-item">Field / 田野</a>
        </div>
    </nav>

    <section class="py-40 bg-white">
        <div class="content-container px-6">
            <div class="mb-20 text-center">
                <span class="font-sans text-[10px] tracking-[0.4em] uppercase opacity-30">Latest Manuscript</span>
            </div>
            
            {allEssays.map((essay) => (
                <article class="mb-40 group">
                    <div class="text-center mb-10">
                        <span class="text-[#0A9C49] text-[10px] font-black tracking-[0.3em] uppercase">{essay.data.category}</span>
                        <a href={`/essays/${essay.slug}`}>
                            <h2 class="text-5xl md:text-6xl font-bold leading-tight mt-6 mb-8 hover:italic transition-all duration-500">
                                {essay.data.title}
                            </h2>
                        </a>
                        <div class="w-12 h-[1px] bg-black mx-auto mb-10 opacity-20"></div>
                        <p class="text-xl leading-relaxed text-gray-600 font-light italic">
                            {essay.data.description}
                        </p>
                    </div>
                    <div class="text-center">
                        <a href={`/essays/${essay.slug}`} class="inline-block text-[10px] font-bold uppercase tracking-[0.2em] border border-black px-8 py-3 hover:bg-black hover:text-white transition-all">
                            Read More
                        </a>
                    </div>
                </article>
            ))}
        </div>
    </section>

    <section class="py-32 bg-[#EEC43E] border-y border-black">
        <div class="max-w-2xl mx-auto px-6 text-center">
            <h3 class="text-4xl font-black uppercase tracking-tighter mb-6 italic" style="font-family: 'Playfair Display', serif;">The Newsletter</h3>
            <p class="text-sm leading-relaxed mb-10 font-medium max-w-md mx-auto">
                订阅 Rui & Ruibeet 的双语档案。关于文学的物理空间、电影的边界以及数字时代的田野观察。
            </p>
            <div class="flex flex-col md:flex-row gap-4">
                <input type="email" placeholder="Email Address" class="flex-1 p-4 bg-white border-2 border-black outline-none font-sans text-sm" />
                <button class="px-10 py-4 bg-black text-white font-black text-xs uppercase tracking-widest hover:bg-white hover:text-black transition-all border-2 border-black">
                    Subscribe
                </button>
            </div>
        </div>
    </section>

    <footer class="py-40 bg-[#A7C9D5]">
        <div class="max-w-screen-xl mx-auto px-6 text-center">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20 max-w-3xl mx-auto">
                <div class="aspect-square bg-white border border-black flex items-center justify-center text-[10px] font-bold uppercase tracking-widest rotate-3 hover:rotate-0 transition-transform cursor-pointer">Fiction</div>
                <div class="aspect-square bg-[#0A9C49] border border-black -rotate-3 hover:rotate-0 transition-transform"></div>
                <div class="aspect-square bg-[#DF9225] border border-black rotate-6 hover:rotate-0 transition-transform"></div>
                <div class="aspect-square bg-[#F3DE16] border border-black -rotate-6 hover:rotate-0 transition-transform"></div>
            </div>
            <p class="text-[10px] tracking-[0.5em] uppercase font-bold">EST. 2026 / RUI & RUIBEET ARCHIVE</p>
        </div>
    </footer>

</body>
</html>
