---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays').catch(() => []);
const latestEssays = allEssays
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const title = "Rui & Ruibeet";
const subtitle = "She's got a lot to say before going to hell";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #A7C9D4;
            --border-color: #000000;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: #1a1a1a; 
            line-height: 1.6;
        }

        /* 1. Header & Title */
        header { padding: 100px 20px 60px; text-align: center; }
        .main-title { 
            font-family: 'Playfair Display', serif; 
            font-size: clamp(50px, 10vw, 100px); 
            font-weight: 700; 
            letter-spacing: -0.02em;
            line-height: 0.9;
        }
        .subtitle { 
            font-family: 'Cinzel', serif; 
            font-size: 11px; 
            letter-spacing: 0.5em; 
            text-transform: uppercase; 
            opacity: 0.6; 
            margin-top: 30px; 
        }

        /* 2. 中英双语导航栏 */
        nav { 
            position: sticky; top: 0; z-index: 100; 
            padding: 20px 40px;
            background: rgba(167, 201, 212, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }
        .nav-container { 
            display: flex; max-width: 1200px; margin: 0 auto; 
            border: 2.5px solid var(--border-color); 
            box-shadow: 6px 6px 0px var(--border-color);
        }
        .nav-item { 
            flex: 1; position: relative; padding: 12px 5px; text-align: center; 
            text-decoration: none; color: white !important; 
            border-right: 2.5px solid var(--border-color); 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex; flex-direction: column; gap: 2px;
        }
        .nav-item:last-child { border-right: none; }
        .nav-item .cn { font-family: 'ZCOOL XiaoWei', serif; font-size: 15px; }
        .nav-item .en { font-family: 'Cinzel', serif; font-size: 8px; opacity: 0.9; letter-spacing: 1px; }
        
        .nav-item:hover { background-color: white !important; transform: translateY(-2px); }
        .nav-item:hover span { color: black !important; }

        /* --- 小说下拉菜单逻辑 --- */
        .dropdown-content {
            display: none;
            position: absolute;
