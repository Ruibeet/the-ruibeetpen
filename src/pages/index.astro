---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays').catch(() => []);
const latestEssays = allEssays
  .sort((a, b) => {
    const dateA = a.data.date instanceof Date ? a.data.date : new Date(a.data.date);
    const dateB = b.data.date instanceof Date ? b.data.date : new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  });

const title = "Rui & Ruibeet";
const subtitle = "She's got a lot to say before going to hell";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #A7C9D4;
            --border-color: #000000;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: #1a1a1a; 
            line-height: 1.6;
        }

        header.home-header { padding: 100px 20px 60px; text-align: center; }
        .main-title { 
            font-family: 'Playfair Display', serif; 
            font-size: clamp(50px, 10vw, 100px); 
            font-weight: 700; 
            letter-spacing: -0.02em;
            line-height: 0.9;
        }
        .subtitle { 
            font-family: 'Cinzel', serif; 
            font-size: 11px; 
            letter-spacing: 0.5em; 
            text-transform: uppercase; 
            opacity: 0.6; 
            margin-top: 30px; 
        }

        nav.home-nav { 
            position: sticky; top: 0; z-index: 100; 
            padding: 20px 40px;
            background: rgba(167, 201, 212, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }
        .home-nav-container { 
            display: flex; max-width: 1200px; margin: 0 auto; 
            border: 2.5px solid var(--border-color); 
            box-shadow: 6px 6px 0px var(--border-color);
            background: white; /* 恢复白色底色 */
        }
        .home-nav-item { 
            flex: 1; position: relative; padding: 12px 5px; text-align: center; 
            text-decoration: none; color: white !important; 
            border-right: 2.5px solid var(--border-color); 
            transition: all 0.3s ease;
            display: flex; flex-direction: column; gap: 2px;
            cursor: pointer;
        }
        .home-nav-item:last-child { border-right: none; }
        .home-nav-item .cn { font-family: 'ZCOOL XiaoWei', serif; font-size: 15px; color: inherit; }
        .home-nav-item .en { font-family: 'Cinzel', serif; font-size: 8px; opacity: 0.9; letter-spacing: 1px; color: inherit; }
        
        .home-nav-item:hover { background-color: white !important; }
        .home-nav-item:hover .cn, .home-nav-item:hover .en { color: black !important; }

        /* 下拉菜单逻辑 */
        .dropdown-content {
            display: none;
            position: absolute;
            top: 100%;
            left: -2.5px;
            width: calc(100% + 5px);
            border: 2.5px solid var(--border-color);
            box-shadow: 6px 6px 0px var(--border-color);
            z-index: 1000;
        }
        .home-nav-item:hover .dropdown-content { display: block; }

        .dropdown-link {
            display: block;
            padding: 15px 10px;
            text-decoration: none;
            color: white !important;
            border-bottom: 2.5px solid var(--border-color);
            transition: 0.2s;
            text-align: center;
        }
        .dropdown-link:last-child { border-bottom: none; }
        .dropdown-link:hover { background-color: white !important; }
        .dropdown-link:hover .cn, .dropdown-link:hover .en { color: black !important; }

        /* 内容列表 */
        .content-grid { max-width: 1100px; margin: 80px auto; padding: 0 40px; }
        .essay-card { 
            display: grid; grid-template-columns: 1.2fr 1fr; gap: 60px;
            margin-bottom: 120px; text-decoration: none; color: black; align-items: center;
        }
        .essay-card:nth-child(even) { grid-template-columns: 1fr 1.2fr; }
        .essay-card:nth-child(even) .card-image-wrapper { order: 2; }
        .card-image-wrapper {
            position: relative; border: 2px solid black; padding: 10px;
            background: white; box-shadow: 15px 15px 0px rgba(0,0,0,0.05); transition: 0.4s;
        }
        .card-image { width: 100%; height: 450px; object-fit: cover; }
        .essay-title { font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 700; margin: 20px 0; }
        .essay-desc { font-size: 16px; line-height: 1.8; opacity: 0.8; }

        /* Newsletter & Support */
        .newsletter-box {
            max-width: 900px; margin: 100px auto; background: #EEC43E;
            border: 3px solid black; padding: 80px 40px; text-align: center; box-shadow: 15px 15px 0px black;
        }
        .email-form { display: flex; justify-content: center; max-width: 500px; margin: 40px auto 0; }
        .email-form input { flex: 1; padding: 15px; border: 2px solid black; border-right: none; outline: none; }
        .email-form button { background: black; color: white; padding: 0 30px; border: 2px solid black; cursor: pointer; }

        .patron-section { padding-bottom: 120px; text-align: center; }
        .patron-card { 
            display: inline-block; background: white; border: 2.5px solid black;
            padding: 60px 80px; box-shadow: 12px 12px 0px #0A9C49;
        }
        .redbull-btn { 
            display: inline-block; background: black; color: white; padding: 18px 40px;
            text-decoration: none; font-family: 'Cinzel'; font-weight: 700;
        }

        footer { padding: 100px 0; text-align: center; opacity: 0.3; font-size: 10px; letter-spacing: 0.5em; }

        @media (max-width: 768px) {
            .essay-card, .essay-card:nth-child(even) { grid-template-columns: 1fr; gap: 30px; }
            .card-image-wrapper { order: 1 !important; }
        }
    </style>
</head>
<body>

    <header class="home-header">
        <h1 class="main-title">{title}</h1>
        <p class="subtitle">{subtitle}</p>
    </header>

    <nav class="home-nav">
        <div class="home-nav-container">
            <a href="/" class="home-nav-item" style="background-color: #000000;">
                <span class="cn">首页</span><span class="en">Home</span>
            </a>
            
            <div class="home-nav-item" style="background-color: #0A9C49;">
                <span class="cn">小说</span><span class="en">Fiction</span>
                <div class="dropdown-content" style="background-color: #0A9C49;">
                    <a href="/novel/long-form" class="dropdown-link">
                        <span class="cn">中长篇</span><span class="en">Novels</span>
                    </a>
                    <a href="/novel/short-stories" class="dropdown-link">
                        <span class="cn">短篇小说</span><span class="en">Short Stories</span>
                    </a>
                </div>
            </div>

            <a href="/essays" class="home-nav-item" style="background-color: #DF9225;">
                <span class="cn">杂文</span><span class="en">Blogs</span>
            </a>

            <a href="/life" class="home-nav-item" style="background-color: #EEC43E; color: black !important;">
                <span class="cn">生活</span><span class="en">Life</span>
            </a>

            <div class="home-nav-item" style="background-color: #F3DE16; color: black !important; cursor: default;">
                <span class="cn">田野</span><span class="en">Field</span>
                <div class="dropdown-content" style="background-color: #F3DE16;">
                    <a href="/field/100-people" class="dropdown-link">
                        <span class="cn">100人</span><span class="en">100 People</span>
                    </a>
                    <a href="/field/roots" class="dropdown-link">
                        <span class="cn">根</span><span class="en">Roots</span>
                    </a>
                    <a href="/field/mountains" class="dropdown-link">
                        <span class="cn">山</span><span class="en">Mountains</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="content-grid">
        {latestEssays.map((essay) => (
            <a href={`/essays/${essay.slug}`} class="essay-card">
                <div class="card-image-wrapper">
                    <img src={essay.data.image || 'https://via.placeholder.com/800x600'} alt={essay.data.title} class="card-image" />
                </div>
                <div class="card-text">
                    <div class="essay-category">{new Date(essay.data.date).getFullYear()} / {essay.data.category}</div>
                    <h2 class="essay-title">{essay.data.title}</h2>
                    <p class="essay-desc">{essay.data.description}</p>
                </div>
            </a>
        ))}
    </main>

    <section class="newsletter-box">
        <h3>The Newsletter</h3>
        <p>DIGITAL FIELD OBSERVATIONS & LITERARY SPACE</p>
        <form class="email-form">
            <input type="email" placeholder="EMAIL ADDRESS" />
            <button type="submit">SIGN UP</button>
        </form>
    </section>

    <section class="patron-section">
        <div class="patron-card">
            <h4>支持Rui的写作</h4>
            <span class="en-sub">Support Rui's Writing</span>
            <div class="patron-text">
                <p>如果你喜欢我写的东西，欢迎请我喝罐红牛。</p>
            </div>
            <a href="#" class="redbull-btn">SPONSOR A RED BULL</a>
        </div>
    </section>

    <footer>EST. 2026 / RUI & RUIBEET ARCHIVE</footer>

</body>
</html>
