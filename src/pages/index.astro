---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays').catch(() => []);
const title = "Rui & Ruibeet";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@200;900&family=Playfair+Display:ital,wght@1,900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style shadow:focus>
        /* 强制背景色和字体，防止缓存 */
        body { font-family: 'Noto Serif SC', serif; background-color: white !important; margin: 0; }
        .serif-title { font-family: 'Playfair Display', serif; font-style: italic; }
        .nav-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); border: 2px solid black; }
        .nav-item { padding: 1.5rem; text-align: center; border-right: 2px solid black; font-weight: 900; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.2em; text-decoration: none; color: white !important; }
        .nav-item:last-child { border-right: none; }
    </style>
</head>
<body class="antialiased">

    <header class="py-32 px-6 bg-white text-center">
        <h1 class="text-7xl md:text-[120px] font-black tracking-tighter serif-title text-black">
            {title}
        </h1>
        <p class="font-sans text-[11px] tracking-[0.5em] uppercase opacity-40 mt-4">Literary Archive & Digital Field</p>
    </header>

    <nav class="sticky top-0 z-50 px-4 md:px-10 bg-white/80 backdrop-blur">
        <div class="nav-grid shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
            <a href="/" class="nav-item" style="background-color: #000000 !important;">Home</a>
            <a href="/novel" class="nav-item" style="background-color: #DF9225 !important;">Fiction</a>
            <a href="/essays" class="nav-item" style="background-color: #0A9C49 !important;">Essays</a>
            <a href="/life" class="nav-item" style="background-color: #A7C9D5 !important;">Life</a>
            <a href="/field" class="nav-item" style="background-color: #EEC43E !important; color: black !important;">Field</a>
        </div>
    </nav>

    <section class="py-40 bg-white">
        <div class="max-w-[750px] mx-auto px-6">
            {allEssays.map((essay) => (
                <article class="mb-48 text-center group">
                    <span class="text-[#0A9C49] text-[10px] font-black tracking-[0.4em] uppercase">{essay.data.category}</span>
                    <a href={`/essays/${essay.slug}`} class="block mt-6 mb-10">
                        <h2 class="text-5xl md:text-6xl font-black leading-tight group-hover:italic transition-all duration-500">
                            {essay.data.title}
                        </h2>
                    </a>
                    <div class="w-16 h-[1px] bg-black/20 mx-auto mb-10"></div>
                    <p class="text-xl leading-relaxed text-gray-700 italic font-light px-4">
                        {essay.data.description}
                    </p>
                    <a href={`/essays/${essay.slug}`} class="inline-block mt-12 text-[10px] font-bold uppercase tracking-widest border-2 border-black px-10 py-4 hover:bg-black hover:text-white transition-all">
                        Open Archive
                    </a>
                </article>
            ))}
        </div>
    </section>

    <section class="py-32" style="background-color: #EEC43E !important; border-top: 2px solid black; border-bottom: 2px solid black;">
        <div class="max-w-2xl mx-auto px-6 text-center">
            <h3 class="text-4xl font-black italic serif-title mb-6">The Newsletter</h3>
            <p class="text-sm mb-10 font-medium">订阅双语档案：文学空间、电影边界与数字观察。</p>
            <div class="flex flex-col md:flex-row gap-2">
                <input type="email" placeholder="EMAIL" class="flex-1 p-4 bg-white border-2 border-black outline-none font-bold" />
                <button class="bg-black text-white px-10 py-4 font-black uppercase text-xs border-2 border-black hover:bg-white hover:text-black transition-all">
                    Subscribe
                </button>
            </div>
        </div>
    </section>

    <footer class="py-40" style="background-color: #A7C9D5 !important;">
        <div class="text-center">
            <div class="inline-block border-4 border-black p-8 bg-white rotate-3 mb-10">
                <span class="text-4xl font-black tracking-tighter italic serif-title">R&R</span>
            </div>
            <p class="text-[10px] tracking-[0.5em] uppercase font-black opacity-60">Est. 2026 / Beijing • Leiden</p>
        </div>
    </footer>

</body>
</html>
