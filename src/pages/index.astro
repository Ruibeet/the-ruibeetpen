---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays').catch(() => []);
// 按时间排序并只取前3篇
const latestEssays = allEssays
  .sort((a, b) => {
    const dateA = a.data.date instanceof Date ? a.data.date : new Date(a.data.date);
    const dateB = b.data.date instanceof Date ? b.data.date : new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  })
  .slice(0, 3);

const title = "Rui & Ruibeet";
const subtitle = "She's got a lot to say before going to hell";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #A7C9D4;
            --border-color: #000000;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: #1a1a1a; 
            line-height: 1.6;
            overflow-x: hidden; /* 防止移动端溢出 */
        }

        /* --- Header & Nav (保持不变) --- */
        header.home-header { padding: 80px 20px 50px; text-align: center; }
        .main-title { 
            font-family: 'Playfair Display', serif; 
            font-size: clamp(40px, 8vw, 80px); 
            font-weight: 700; 
            letter-spacing: -0.02em;
            line-height: 1.0;
        }
        .subtitle { 
            font-family: 'Cinzel', serif; 
            font-size: 10px; 
            letter-spacing: 0.5em; 
            text-transform: uppercase; 
            opacity: 0.6; 
            margin-top: 25px; 
        }

        nav.home-nav { 
            position: sticky; top: 0; z-index: 100; 
            padding: 15px 30px;
            background: rgba(167, 201, 212, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }
        .home-nav-container { 
            display: flex; max-width: 1100px; margin: 0 auto; 
            border: 2px solid var(--border-color); 
            box-shadow: 5px 5px 0px var(--border-color);
            background: white;
        }
        .home-nav-item { 
            flex: 1; position: relative; padding: 10px 5px; text-align: center; 
            text-decoration: none; color: white !important; 
            border-right: 2px solid var(--border-color); 
            transition: all 0.3s ease;
            display: flex; flex-direction: column; gap: 2px;
            cursor: pointer;
        }
        .home-nav-item:last-child { border-right: none; }
        .home-nav-item .cn { font-family: 'ZCOOL XiaoWei', serif; font-size: 14px; color: inherit; }
        .home-nav-item .en { font-family: 'Cinzel', serif; font-size: 8px; opacity: 0.9; letter-spacing: 1px; color: inherit; }
        .home-nav-item:hover { background-color: white !important; }
        .home-nav-item:hover .cn, .home-nav-item:hover .en { color: black !important; }

        .dropdown-content {
            display: none; position: absolute; top: 100%; left: -2px; width: calc(100% + 4px);
            border: 2px solid var(--border-color); box-shadow: 5px 5px 0px var(--border-color); z-index: 1000;
        }
        .home-nav-item:hover .dropdown-content { display: block; }
        .dropdown-link {
            display: block; padding: 12px 10px; text-decoration: none; color: white !important;
            border-bottom: 2px solid var(--border-color); transition: 0.2s; text-align: center;
        }
        .dropdown-link:last-child { border-bottom: none; }
        .dropdown-link:hover { background-color: white !important; }
        .dropdown-link:hover .cn, .dropdown-link:hover .en { color: black !important; }

        /* --- ✨ 新的紧凑型三列内容列表 --- */
        .content-grid-wrapper {
            max-width: 1200px;
            margin: 60px auto 100px;
            padding: 0 30px;
        }
        
        .compact-essay-grid { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); /* ✨ 强制一行三列 */
            gap: 30px; 
        }

        .essay-card { 
            display: block; /* 整个卡片都是链接 */
            background: white;
            border: 2px solid var(--border-color); 
            box-shadow: 8px 8px 0px var(--border-color); /* 统一的硬核阴影 */
            text-decoration: none; 
            color: black; 
            transition: 0.3s ease;
            overflow: hidden; /* 防止图片溢出 */
            height: 100%; /* 确保卡片等高 */
            display: flex;
            flex-direction: column; /* 内容垂直排列 */
        }
        
        /* 鼠标悬停时的微互动 */
        .essay-card:hover {
            transform: translate(-3px, -3px);
            box-shadow: 11px 11px 0px var(--border-color);
        }

        .card-image-wrapper {
            width: 100%;
            height: 220px; /* ✨ 固定高度，缩小图片 */
            border-bottom: 2px solid black; /* 图片与文字分割线 */
            overflow: hidden;
        }
        
        .card-image { 
            width: 100%; 
            height: 100%; 
            object-fit: cover; /* 确保图片覆盖且不变形 */
            transition: transform 0.4s ease; /* 图片悬停放大效果 */
        }
        
        .essay-card:hover .card-image {
            transform: scale(1.05); /* 微小的放大感 */
        }

        .card-text-content {
            padding: 25px; /* 文字内容的内边距 */
            flex-grow: 1; /* 让文字部分占据剩余空间，确保等高 */
            display: flex;
            flex-direction: column;
            justify-content: space-between; /* 将元数据推到底部 */
        }

        .essay-title { 
            font-family: 'Playfair Display', serif; 
            font-size: 26px; /* ✨ 缩小标题字体 */
            font-weight: 700; 
            line-height: 1.3;
            margin-bottom: 12px;
            color: black;
            /* 标题截断：最多显示三行 */
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .essay-desc { 
            font-size: 14px; /* ✨ 缩小描述字体 */
            line-height: 1.6; 
            opacity: 0.7; 
            color: #333;
            margin-bottom: 20px;
            /* 描述截断：最多显示四行 */
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .card-meta {
            font-family: 'Cinzel', serif;
            font-size: 9px;
            letter-spacing: 2px;
            opacity: 0.4;
            display: block;
            margin-top: auto; /* 推到底部 */
            padding-top: 15px;
            border-top: 1px solid rgba(0,0,0,0.1); /* 淡淡的分隔线 */
        }

        /* --- 查看全部档案按钮 (推荐增加) --- */
        .view-all-wrapper {
            text-align: center;
            margin: -20px 0 100px;
        }
        .view-all-btn {
            display: inline-block;
            padding: 15px 40px;
            border: 2px solid black;
            background: white;
            color: black;
            text-decoration: none;
            font-family: 'Cinzel', serif;
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 3px;
            box-shadow: 6px 6px 0px black;
            transition: 0.3s ease;
        }
        .view-all-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 8px 8px 0px black;
        }

        /* --- Newsletter & Patron (保持不变) --- */
        .home-newsletter-box {
            max-width: 900px; margin: 0 auto 100px; background: #EEC43E;
            border: 3px solid black; padding: 60px 40px; text-align: center; box-shadow: 15px 15px 0px black;
        }
        .home-newsletter-box h2 {
            font-family: 'Cinzel', serif;
            font-size: clamp(36px, 6vw, 56px); margin-bottom: 20px; letter-spacing: 10px; font-weight: 700;
            text-transform: uppercase; color: black;
        }
        .newsletter-desc {
            font-family: 'Playfair Display', serif;
            font-size: 13px; opacity: 0.7; letter-spacing: 2px; margin-bottom: 40px;
        }
        .home-newsletter-box .email-form { display: flex; justify-content: center; max-width: 500px; margin: 0 auto; }
        .home-newsletter-box .email-form input { flex: 1; padding: 12px; border: 2px solid black; border-right: none; outline: none; font-family: 'Noto Serif SC', serif; }
        .home-newsletter-box .email-form button { 
            background: black; color: white; padding: 0 30px; border: 2px solid black; cursor: pointer; 
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px;
        }
        .home-newsletter-box .email-form button .cn { font-family: 'ZCOOL XiaoWei', serif; font-size: 14px; font-weight: bold; }
        .home-newsletter-box .email-form button .en { font-family: 'Cinzel', serif; font-size: 7px; letter-spacing: 1px; }
        .free-sub-notice { font-family: 'Noto Serif SC', serif; font-size: 10px; opacity: 0.5; margin-top: 15px; letter-spacing: 2px; }

        .home-patron-section { padding-bottom: 100px; text-align: center; }
        .home-patron-card { 
            display: inline-block; background: white; border: 2.5px solid black;
            padding: 50px 60px; box-shadow: 12px 12px 0px #0A9C49; max-width: 650px;
        }
        .home-patron-card h3 { font-family: 'ZCOOL XiaoWei', serif; font-size: 28px; margin-bottom: 10px; color: black; }
        .home-patron-card .en-sub { font-family: 'Playfair Display', serif; font-style: italic; opacity: 0.6; display: block; font-size: 11px; margin-bottom: 30px; }
        .home-patron-card .patron-text p { font-family: 'Noto Serif SC', serif; font-size: 14px; line-height: 1.8; color: #1a1a1a; margin-bottom: 8px;}
        .redbull-btn { 
            display: inline-block; background: black; color: white; padding: 18px 40px; margin-top: 35px;
            text-decoration: none; font-family: 'Cinzel', serif; font-weight: 700; font-size: 12px; letter-spacing: 2px;
        }

        footer { padding: 80px 0; text-align: center; opacity: 0.3; font-size: 9px; letter-spacing: 0.5em; }

        /* --- 响应式适配 --- */
        @media (max-width: 900px) {
            .compact-essay-grid { grid-template-columns: 1fr; gap: 40px; } /* 移动端切回一列 */
            .essay-card { max-width: 450px; margin: 0 auto; }
            .content-grid-wrapper { padding: 0 20px; }
        }
        @media (max-width: 768px) {
            .home-patron-card { padding: 30px 20px; }
            .home-newsletter-box { padding: 40px 20px; }
        }
    </style>
</head>
<body>

    <header class="home-header">
        <h1 class="main-title">{title}</h1>
        <p class="subtitle">{subtitle}</p>
    </header>

    <nav class="home-nav">
        <div class="home-nav-container">
            <a href="/" class="home-nav-item" style="background-color: #000000;">
                <span class="cn">首页</span><span class="en">Home</span>
            </a>
            
            <div class="home-nav-item" style="background-color: #0A9C49;">
                <span class="cn">小说</span><span class="en">Fiction</span>
                <div class="dropdown-content" style="background-color: #0A9C49;">
                    <a href="/novel/long-form" class="dropdown-link">
                        <span class="cn">中长篇</span><span class="en">Novels</span>
                    </a>
                    <a href="/novel/short-stories" class="dropdown-link">
                        <span class="cn">短篇小说</span><span class="en">Short Stories</span>
                    </a>
                </div>
            </div>

            <a href="/essays" class="home-nav-item" style="background-color: #DF9225;">
                <span class="cn">杂文</span><span class="en">Blogs</span>
            </a>

            <a href="/life" class="home-nav-item" style="background-color: #EEC43E; color: black !important;">
                <span class="cn">生活</span><span class="en">Life</span>
            </a>

            <div class="home-nav-item" style="background-color: #F3DE16; color: black !important; cursor: default;">
                <span class="cn">田野</span><span class="en">Field</span>
                <div class="dropdown-content" style="background-color: #F3DE16;">
                    <a href="/field/100-people" class="dropdown-link">
                        <span class="cn">100人</span><span class="en">100 People</span>
                    </a>
                    <a href="/field/roots" class="dropdown-link">
                        <span class="cn">根</span><span class="en">Roots</span>
                    </a>
                    <a href="/field/mountains" class="dropdown-link">
                        <span class="cn">山</span><span class="en">Mountains</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="content-grid-wrapper">
        <div class="compact-essay-grid">
            {latestEssays.map((essay) => (
                <a href={`/essays/${essay.slug}`} class="essay-card">
                    <div class="card-image-wrapper">
  {
    essay.data.image ? (
      <img 
        src={essay.data.image.startsWith('./') 
          ? `/src/content/essays/${essay.data.image.replace('./', '')}` 
          : essay.data.image} 
        alt={essay.data.title} 
        class="card-image" 
      />
    ) : (
      <img src="https://via.placeholder.com/800x600" alt="Placeholder" class="card-image" />
    )
  }
</div>
                    <div class="card-text-content">
                        <div>
                            <h2 class="essay-title">{essay.data.title}</h2>
                            <p class="essay-desc">{essay.data.description}</p>
                        </div>
                        <small class="card-meta">
                            {new Date(essay.data.date).getFullYear()} // {essay.data.category} // Rui's Archive
                        </small>
                    </div>
                </a>
            ))}
        </div>
    </main>

    <div class="view-all-wrapper">
        <a href="/essays" class="view-all-btn">
            VIEW ALL ARCHIVE
        </a>
    </div>

    <section class="home-newsletter-box">
        <div class="newsletter-wrapper">
            <h2>NEWSLETTER</h2>
            <div class="newsletter-desc">
                <span class="en">Digital Field Observations & Literary Space</span>
            </div>
            <form class="email-form">
                <input type="email" placeholder="EMAIL ADDRESS" required />
                <button type="submit">
                    <span class="cn">订阅</span>
                    <span class="en">(Subscribe)</span>
                </button>
            </form>
            <p class="free-sub-notice">免费订阅 (Free Subscription)</p>
        </div>
    </section>

    <section class="home-patron-section">
        <div class="home-patron-card">
            <h3>支持Rui的写作</h3>
            <span class="en-sub">Support Rui's Writing</span>
            <div class="patron-text">
                <p>如果你喜欢我写的东西，欢迎请我喝罐红牛。</p>
                <p style="font-size: 13px; opacity: 0.5; margin-top: 8px;">
                    If you enjoy my writings, feel free to buy me a Red Bull.
                </p>
            </div>
            <a href="#" class="redbull-btn">SPONSOR A RED BULL</a>
        </div>
    </section>

    <footer>EST. 2026 / RUI & RUIBEET ARCHIVE</footer>

</body>
</html>
