---
// 这里是你的 Vibe 控制面板
const title = "THE ARCHIVE";
const categories = [
  { name: '主页', color: '#000000', link: '/' },
  { name: '小说', color: '#DF9225', link: '/novel' },
  { name: '杂文', color: '#009C49', link: '/essays' },
  { name: '生活', color: '#A7C9D5', link: '/life' }
];
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&display=swap" rel="stylesheet">
		<script src="https://cdn.tailwindcss.com"></script>
		<style>
			body { font-family: 'Noto Serif SC', serif; }
			.vibe-bg-yellow { background-color: #EEC43E; }
			.vibe-text-green { color: #0A9C49; }
		</style>
	</head>
	<body class="bg-white text-black antialiased">
		<nav class="border-b border-black py-8 px-6 md:px-16 flex flex-col md:flex-row justify-between items-center">
			<h1 class="text-4xl font-black tracking-tighter cursor-pointer uppercase">{title}</h1>
			<div class="flex gap-8 text-sm uppercase tracking-widest mt-6 md:mt-0">
				{categories.map(cat => (
					<a href={cat.link} style={`color: ${cat.color}`} class="hover:underline decoration-2 font-bold transition-all">
						{cat.name}
					</a>
				))}
			</div>
		</nav>

		<main class="max-w-6xl mx-auto px-6 py-20">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-16">
				<section class="md:col-span-8 border-r border-gray-100 pr-0 md:pr-16">
					<article class="group cursor-pointer">
						<p class="vibe-text-green text-xs font-bold tracking-[0.2em] mb-4 uppercase">最新发布 / 杂文</p>
						<h2 class="text-5xl leading-[1.1] font-bold mb-8 group-hover:text-[#DF9225] transition-colors">
							文本的边界：论当代数字文学的物理空间与感知
						</h2>
						<div class="h-[400px] bg-[#A7C9D5] mb-8 flex items-center justify-center text-white/40 text-6xl font-black">
							FEATURED IMAGE
						</div>
						<p class="text-xl leading-relaxed text-gray-800 italic mb-6">
							“在这个信息过载的时代，留白不仅是视觉的奢侈，更是思想的避难所。”
						</p>
					</article>
				</section>

				<aside class="md:col-span-4 flex flex-col gap-12">
					<div class="vibe-bg-yellow p-10 shadow-[-10px_10px_0px_0px_rgba(0,0,0,1)]">
						<h3 class="text-xl font-bold mb-4">加入订阅名单</h3>
						<p class="text-sm leading-relaxed mb-6 text-black/80">
							获取深度文学评论与最新连载。支持与 微信公众号 同步。
						</p>
						<input type="email" placeholder="你的邮箱" class="w-full p-3 border border-black text-sm mb-4 outline-none focus:ring-2 ring-[#0A9C49]" />
						<button class="w-full bg-black text-white py-3 font-bold text-sm hover:bg-[#0A9C49] transition-all">
							SUBSCRIBE
						</button>
					</div>

					<div class="border-t-4 border-[#DF9225] pt-6">
						<h3 class="font-bold text-sm tracking-widest mb-4 uppercase">Patreon Support</h3>
						<p class="text-sm text-gray-600 leading-loose">
							支持我的长篇小说连载，获取独家创作日记与手稿。
						</p>
						<a href="#" class="inline-block mt-4 text-[#DF9225] font-bold border-b border-[#DF9225] hover:text-black hover:border-black transition-all text-sm">去资助我的创作 →</a>
					</div>
				</aside>
			</div>
		</main>

		<footer class="mt-32 py-12 border-t border-black px-6 text-center text-[10px] tracking-[0.3em] uppercase">
			© 2026 {title} / Built with Gemini Vibe Coding
		</footer>
	</body>
</html>
