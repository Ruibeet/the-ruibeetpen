---
import { getCollection } from 'astro:content';
const allEssays = await getCollection('essays');
// 按时间排序并取前两篇
const latestTwo = allEssays.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 2);
const title = "Rui & Ruibeet";
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;900&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        body { background-color: #A7C9D4; margin: 0; font-family: 'Noto Serif SC', serif; }
        .nav-container { display: flex; border: 2.5px solid black; box-shadow: 8px 8px 0px black; margin: 0 40px; position: sticky; top: 20px; z-index: 100; }
        .nav-item { flex: 1; padding: 20px; text-align: center; text-decoration: none; color: white !important; font-weight: 700; font-size: 12px; border-right: 2.5px solid black; }
        .nav-item:last-child { border-right: none; }
        
        /* 首页大图文章卡片 */
        .featured-grid { display: grid; grid-template-cols: 1fr; gap: 60px; max-width: 900px; margin: 100px auto; padding: 0 20px; }
        .feature-card { background: white; border: 2px solid black; overflow: hidden; }
        .feature-image { width: 100%; height: 450px; object-fit: cover; border-bottom: 2px solid black; }
        .feature-content { padding: 40px; text-align: center; }
        .essay-title { font-family: 'ZCOOL XiaoWei', serif; font-size: 42px; margin: 20px 0; color: black; text-decoration: none; display: block; }
        .essay-title:hover { opacity: 0.7; }
    </style>
</head>
<body>
    <header style="padding: 100px 0; text-align: center;">
        <h1 style="font-family: 'Playfair Display'; font-size: 80px; font-weight: 400;">{title}</h1>
        <p style="letter-spacing: 0.3em; opacity: 0.6;">She's got a lot to say before going to hell</p>
    </header>

    <nav class="nav-container">
        <a href="/" class="nav-item" style="background-color: #000000;">Home</a>
        <a href="/novel" class="nav-item" style="background-color: #0A9C49;">Fiction</a>
        <a href="/essays" class="nav-item" style="background-color: #DF9225;">Essays</a>
        <a href="/life" class="nav-item" style="background-color: #EEC43E; color: black !important;">Life</a>
        <a href="/field" class="nav-item" style="background-color: #F3DE16; color: black !important;">Field</a>
    </nav>

    <main class="featured-grid">
        {latestTwo.map(essay => (
            <div class="feature-card">
                {essay.data.image && <img src={essay.data.image} class="feature-image" />}
                <div class="feature-content">
                    <span style="color: #DF9225; font-weight: 900; letter-spacing: 0.2em;">{essay.data.category} / {essay.data.date.toLocaleDateString()}</span>
                    <a href={`/essays/${essay.slug}`} class="essay-title">{essay.data.title}</a>
                    <p style="font-style: italic; color: #666;">{essay.data.description}</p>
                </div>
            </div>
        ))}
    </main>
</body>
</html>
