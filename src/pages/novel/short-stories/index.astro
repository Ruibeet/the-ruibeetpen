---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const title = "Short Stories";
const subtitle = "Fragments, Flashes, and Fictions";

// 1. 获取内容 (不做任何过滤，确保能抓到)
const shorts = await getCollection('novel');

const sizes = ['large', 'small', 'medium'];
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rui</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg-color: #0A9C49; 
            --border-color: #000000; 
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: white; 
            line-height: 1.6;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 60px 40px; }

        .page-header { margin-bottom: 80px; text-align: left; }
        .page-header h1 { font-family: 'Playfair Display'; font-size: clamp(40px, 8vw, 70px); margin-bottom: 10px; color: white; }
        .page-header p { font-family: 'Cinzel'; letter-spacing: 4px; opacity: 0.7; font-size: 12px; }

        .shorts-grid { 
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            grid-auto-rows: 20px; 
            gap: 40px;
        }

        .short-card {
            background: white;
            border: 2.5px solid black;
            padding: 15px;
            text-decoration: none;
            color: black;
            box-shadow: 8px 8px 0px black;
            transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            display: flex;
            flex-direction: column;
        }

        .short-card.large { grid-row: span 15; }
        .short-card.medium { grid-row: span 12; }
        .short-card.small { grid-row: span 14; }

        .short-card:hover { 
            transform: translate(-4px, -4px); 
            box-shadow: 12px 12px 0px rgba(0,0,0,0.3);
        }

        .short-date { font-family: 'Cinzel'; font-size: 10px; opacity: 0.4; margin-bottom: 15px; }
        
        .short-image-wrapper {
            width: 100%;
            height: 180px;
            overflow: hidden;
            border: 1px solid black;
            margin-bottom: 20px;
            background: #eee;
        }
        
        .short-title { font-family: 'ZCOOL XiaoWei'; font-size: 22px; margin-bottom: 5px; color: black; }
        .short-en { font-family: 'Cinzel'; font-size: 9px; letter-spacing: 1px; opacity: 0.5; margin-bottom: 15px; display: block; }
        .short-desc {
    font-size: 13px;
    line-height: 1.5; /* 稍微调紧行高 */
    opacity: 0.8;
    /* ✨ 新增：超过 3 行自动显示省略号，防止撑开卡片 */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
       .short-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start; /* 确保内容靠上，而不是撑开间距 */
}
        @media (max-width: 768px) {
            .shorts-grid { display: flex; flex-direction: column; }
            .short-card { margin-bottom: 30px; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="page-header">
            <h1>{title}</h1>
            <p>{subtitle}</p>
        </header>

        <main class="shorts-grid">
            {shorts.map((item, index) => {
                const size = sizes[index % sizes.length];
                return (
                    /* 注意：这里链接暂设为 # 因为你还没做详情页 */
                    <a href={`/novel/${item.slug}`} class={`short-card ${size}`}>
                        <div class="short-date">{item.data.date}</div>
                        <div class="short-image-wrapper">
                            {item.data.image && (
                                <Image 
                                    src={item.data.image} 
                                    alt={item.data.title} 
                                    class="short-image"
                                    width={600}
                                    height={800}
                                />
                            )}
                        </div>
                        <div class="short-content">
                            <h2 class="short-title">{item.data.title}</h2>
                            <span class="short-en">NOVEL / {item.data.category}</span>
                            <p class="short-desc">{item.data.description}</p>
                        </div>
                    </a>
                );
            })}
        </main>
        
        <footer style="margin-top: 100px; text-align: center; opacity: 0.6; font-family: 'Cinzel'; font-size: 10px;">
            <p>END OF ARCHIVE / RUI & RUIBEET</p>
        </footer>
    </div>

</body>
</html>
