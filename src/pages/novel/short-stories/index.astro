---
const title = "Short Stories";
const subtitle = "Fragments, Flashes, and Fictions";

// 模拟短篇数据
const shorts = [
    { 
        date: "2026.03.15",
        title: "消失的下午", 
        enTitle: "The Vanishing Afternoon", 
        desc: "他在地铁站台坐了三个小时，直到发现自己忘记了母语。", 
        image: "/api/placeholder/400/300",
        size: "large" // 大块
    },
    { 
        date: "2026.02.28",
        title: "薄荷糖碎片", 
        enTitle: "Peppermint Shards", 
        desc: "关于一场冬日葬礼和永不融化的糖霜。", 
        image: "/api/placeholder/400/500",
        size: "small" // 长块
    },
    { 
        date: "2026.01.10",
        title: "第25小时", 
        enTitle: "The 25th Hour", 
        desc: "如果一天多出一个小时，我们会用来交换什么？", 
        image: "/api/placeholder/500/350",
        size: "medium" // 中块
    }
];
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rui</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg-color: #0A9C49; 
            --border-color: #000000; 
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: white; 
            line-height: 1.6;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 60px 40px; }

        /* 1. Header */
        .page-header { margin-bottom: 80px; text-align: left; }
        .page-header h1 { font-family: 'Playfair Display'; font-size: clamp(40px, 8vw, 70px); margin-bottom: 10px; }
        .page-header p { font-family: 'Cinzel'; letter-spacing: 4px; opacity: 0.7; font-size: 12px; }

        /* 2. 自由块状布局 (Masonry Style Grid) */
        .shorts-grid { 
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            grid-auto-rows: 20px; /* 定义微小行高，方便跨行实现错落感 */
            gap: 40px;
        }

        .short-card {
            background: white;
            border: 2.5px solid black;
            padding: 20px;
            text-decoration: none;
            color: black;
            box-shadow: 8px 8px 0px black;
            transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            display: flex;
            flex-direction: column;
        }

        /* 模拟不同大小的块 */
        .short-card.large { grid-row: span 25; }
        .short-card.medium { grid-row: span 20; }
        .short-card.small { grid-row: span 22; }

        .short-card:hover { 
            transform: translate(-4px, -4px); 
            box-shadow: 15px 15px 0px rgba(0,0,0,0.3);
        }

        .short-date { font-family: 'Cinzel'; font-size: 10px; opacity: 0.4; margin-bottom: 15px; }
        
        .short-image-wrapper {
            width: 100%;
            height: 200px;
            overflow: hidden;
            border: 1px solid black;
            margin-bottom: 20px;
        }
        .short-card.small .short-image-wrapper { height: 250px; } /* 小块里的图可以长一点 */
        
        .short-image { width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%); transition: 0.5s; }
        .short-card:hover .short-image { filter: grayscale(0%); transform: scale(1.05); }

        .short-title { font-family: 'ZCOOL XiaoWei'; font-size: 22px; margin-bottom: 5px; }
        .short-en { font-family: 'Cinzel'; font-size: 9px; letter-spacing: 1px; opacity: 0.5; margin-bottom: 15px; display: block; }
        .short-desc { font-size: 13px; line-height: 1.7; opacity: 0.8; }

        /* 移动端适配 */
        @media (max-width: 768px) {
            .shorts-grid { display: flex; flex-direction: column; }
            .short-card { grid-row: auto !important; margin-bottom: 30px; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="page-header">
            <h1>{title}</h1>
            <p>{subtitle}</p>
        </header>

        <main class="shorts-grid">
            {shorts.map((item) => (
                <a href="#" class={`short-card ${item.size}`}>
                    <div class="short-date">{item.date}</div>
                    <div class="short-image-wrapper">
                        <img src={item.image} alt={item.title} class="short-image" />
                    </div>
                    <div class="short-content">
                        <h2 class="short-title">{item.title}</h2>
                        <span class="short-en">{item.enTitle}</span>
                        <p class="short-desc">{item.desc}</p>
                    </div>
                </a>
            ))}
        </main>

        <footer style="margin-top: 100px; text-align: center; opacity: 0.6; font-family: 'Cinzel'; font-size: 10px;">
            <p>END OF ARCHIVE / SCROLL TO TOP</p>
        </footer>
    </div>

</body>
</html>
