---
const title = "Novellas & Novels";
const subtitle = "The Long-form Fiction Archive";

// 模拟书籍数据（你可以之后替换为实际路径）
const myBooks = [
    { title: "小说题目一", enTitle: "Title One", desc: "这里是关于第一本书的简短介绍。讲述了一个关于记忆、城市与消失的故事。采用半自传体的叙事风格...", image: "/api/placeholder/400/560" },
    { title: "小说题目二", enTitle: "Title Two", desc: "第二本书的介绍。探讨了数字时代的亲密关系，以及人在算法推荐下的情感异化。背景设定在虚构的南方城市...", image: "/api/placeholder/400/560" },
    { title: "小说题目三", enTitle: "Title Three", desc: "第三本书的介绍。这是一部带有田野调查性质的长篇小说，记录了某个衰落工业区的最后三个月...", image: "/api/placeholder/400/560" }
];
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rui</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root { --bg-color: #A7C9D4; --border-color: #000000; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Noto Serif SC', serif; background-color: var(--bg-color); color: #1a1a1a; }

        /* 复用导航栏和页头样式... (建议将导航栏做成组件，这里先保留逻辑) */
        .section-container { max-width: 1100px; margin: 0 auto; padding: 60px 40px; }

        /* 1. 书籍陈列区 (精装书感) */
        .books-grid { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 40px; 
            margin-top: 40px;
        }
        .book-card { text-decoration: none; color: black; }
        .book-cover-wrapper {
            aspect-ratio: 1 / 1.4; /* 标准书籍比例 */
            border: 2px solid black;
            background: white;
            padding: 15px;
            box-shadow: 10px 10px 0px black;
            transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            margin-bottom: 25px;
        }
        .book-card:hover .book-cover-wrapper { transform: translateY(-10px); box-shadow: 15px 15px 0px #0A9C49; }
        .book-cover { width: 100%; height: 100%; object-fit: cover; border: 1px solid rgba(0,0,0,0.1); }
        .book-title { font-family: 'ZCOOL XiaoWei'; font-size: 24px; margin-bottom: 5px; }
        .book-en { font-family: 'Cinzel'; font-size: 10px; letter-spacing: 2px; opacity: 0.5; display: block; margin-bottom: 15px; }
        .book-desc { font-size: 14px; line-height: 1.8; opacity: 0.8; text-align: justify; }

        /* 2. 最新更新列表 (简洁文学感) */
        .updates-section { margin-top: 100px; border-top: 2.5px solid black; padding-top: 60px; }
        .update-item { 
            display: flex; justify-content: space-between; align-items: baseline;
            padding: 20px 0; border-bottom: 1px solid rgba(0,0,0,0.1);
            text-decoration: none; color: black;
        }
        .update-item:hover .update-title { text-decoration: underline; }
        .update-title { font-size: 18px; font-weight: 700; }
        .update-meta { font-family: 'Cinzel'; font-size: 12px; opacity: 0.4; }

        /* 3. 评论区 (简约占位) */
        .comment-section { 
            margin: 100px 0; background: white; border: 2.5px solid black; 
            padding: 60px; box-shadow: 12px 12px 0px black;
        }
        .comment-title { font-family: 'Playfair Display'; font-size: 32px; margin-bottom: 40px; text-align: center; }
        .comment-placeholder { 
            border: 1px dashed #ccc; padding: 40px; text-align: center; color: #999; 
            font-family: 'Cinzel'; letter-spacing: 2px; 
        }

        .page-header { margin-bottom: 80px; }
        .page-header h1 { font-family: 'Playfair Display'; font-size: 60px; }
        .page-header span { font-family: 'ZCOOL XiaoWei'; font-size: 24px; opacity: 0.6; }

        @media (max-width: 768px) {
            .books-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div class="section-container">
        <header class="page-header">
            <span>中长篇小说</span>
            <h1>{title}</h1>
        </header>

        <section class="books-grid">
            {myBooks.map((book) => (
                <a href="#" class="book-card">
                    <div class="book-cover-wrapper">
                        <img src={book.image} alt={book.title} class="book-cover" />
                    </div>
                    <h3 class="book-title">{book.title}</h3>
                    <span class="book-en">{book.enTitle}</span>
                    <p class="book-desc">{book.desc}</p>
                </a>
            ))}
        </section>

        <section class="updates-section">
            <h2 style="font-family: 'ZCOOL XiaoWei'; margin-bottom: 30px;">最新更新</h2>
            <div class="updates-list">
                <a href="#" class="update-item">
                    <span class="update-title">《第一本书》第十二章：回声</span>
                    <span class="update-meta">MARCH 20, 2026</span>
                </a>
                <a href="#" class="update-item">
                    <span class="update-item">《第二本书》番外：另一种结局</span>
                    <span class="update-meta">FEBRUARY 15, 2026</span>
                </a>
            </div>
        </section>

        <section class="comment-section">
            <h2 class="comment-title">Discussions</h2>
            <div class="comment-placeholder">
                COMMENTS MODULE SYSTEM LOADING...
            </div>
        </section>
    </div>

    <footer style="text-align:center; padding: 60px; opacity: 0.3; font-family: 'Cinzel'; font-size: 10px;">
        {new Date().getFullYear()} © RUI & RUIBEET
    </footer>

</body>
</html>
