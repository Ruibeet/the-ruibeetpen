---
const title = "Novellas & Novels";
const subtitle = "The Long-form Fiction Archive";

// 模拟书籍数据（你可以之后替换为实际路径）
const myBooks = [
    { title: "小说题目一", enTitle: "Title One", desc: "这里是关于第一本书的简短介绍。讲述了一个关于记忆、城市与消失的故事。采用半自传体的叙事风格...", image: "/api/placeholder/400/560" },
    { title: "小说题目二", enTitle: "Title Two", desc: "第二本书的介绍。探讨了数字时代的亲密关系，以及人在算法推荐下的情感异化。背景设定在虚构的南方城市...", image: "/api/placeholder/400/560" },
    { title: "小说题目三", enTitle: "Title Three", desc: "第三本书的介绍。这是一部带有田野调查性质的长篇小说，记录了某个衰落工业区的最后三个月...", image: "/api/placeholder/400/560" }
];
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rui</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg-color: #0A9C49; /* 修改为小说专属绿色 */
            --border-color: #000000; 
            --text-color: #ffffff; /* 深色背景下使用白色文字 */
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: var(--text-color); 
            line-height: 1.6;
        }

        .section-container { max-width: 1100px; margin: 0 auto; padding: 60px 40px; }

        /* 1. Page Header */
        .page-header { margin-bottom: 80px; border-bottom: 1.5px solid rgba(255,255,255,0.3); padding-bottom: 30px; }
        .page-header h1 { font-family: 'Playfair Display'; font-size: clamp(40px, 8vw, 70px); color: white; }
        .page-header span { font-family: 'ZCOOL XiaoWei'; font-size: 24px; color: white; opacity: 0.8; }

        /* 2. 书籍陈列区 (白盒子在绿底上会非常跳脱、好看) */
        .books-grid { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 50px; 
            margin-top: 40px;
        }
        .book-card { text-decoration: none; color: white; group; }
        .book-cover-wrapper {
            aspect-ratio: 1 / 1.4; 
            border: 2.5px solid black;
            background: white; /* 封面背景保持白色，形成强烈反差 */
            padding: 12px;
            box-shadow: 12px 12px 0px black;
            transition: 0.5s cubic-bezier(0.2, 1, 0.3, 1);
            margin-bottom: 30px;
            overflow: hidden;
        }
        .book-card:hover .book-cover-wrapper { 
            transform: translate(-5px, -5px); 
            box-shadow: 18px 18px 0px rgba(0,0,0,0.4); 
        }
        .book-cover { width: 100%; height: 100%; object-fit: cover; }
        
        .book-title { font-family: 'ZCOOL XiaoWei'; font-size: 26px; margin-bottom: 8px; color: white; }
        .book-en { font-family: 'Cinzel'; font-size: 10px; letter-spacing: 2.5px; opacity: 0.7; display: block; margin-bottom: 20px; color: white; }
        .book-desc { font-size: 14px; line-height: 1.9; opacity: 0.9; text-align: justify; font-weight: 300; }

        /* 3. 最新更新列表 */
        .updates-section { margin-top: 120px; border-top: 2.5px solid black; padding-top: 60px; }
        .update-item { 
            display: flex; justify-content: space-between; align-items: baseline;
            padding: 25px 0; border-bottom: 1px solid rgba(255,255,255,0.2);
            text-decoration: none; color: white;
            transition: 0.3s;
        }
        .update-item:hover { padding-left: 10px; background: rgba(255,255,255,0.05); }
        .update-title { font-size: 19px; font-weight: 400; font-family: 'Noto Serif SC'; }
        .update-meta { font-family: 'Cinzel'; font-size: 12px; opacity: 0.6; }

        /* 4. 评论区 (深绿背景下的白卡片) */
        .comment-section { 
            margin: 120px 0; background: white; border: 3px solid black; 
            padding: 80px 40px; box-shadow: 15px 15px 0px black;
            color: black; /* 评论区内部文字切回黑色 */
        }
        .comment-title { font-family: 'Playfair Display'; font-size: 36px; margin-bottom: 40px; text-align: center; }
        .comment-placeholder { 
            border: 2px dashed #eee; padding: 60px; text-align: center; color: #999; 
            font-family: 'Cinzel'; letter-spacing: 2px; font-size: 12px;
        }

        @media (max-width: 900px) {
            .books-grid { grid-template-columns: 1fr; }
            .update-item { flex-direction: column; gap: 10px; }
        }
    </style>
</head>
<body>

    <div class="section-container">
        <header class="page-header">
            <span>中长篇小说</span>
            <h1>{title}</h1>
        </header>

        <section class="books-grid">
            {myBooks.map((book) => (
                <a href="#" class="book-card">
                    <div class="book-cover-wrapper">
                        <img src={book.image} alt={book.title} class="book-cover" />
                    </div>
                    <h3 class="book-title">{book.title}</h3>
                    <span class="book-en">{book.enTitle}</span>
                    <p class="book-desc">{book.desc}</p>
                </a>
            ))}
        </section>

        <section class="updates-section">
            <h2 style="font-family: 'ZCOOL XiaoWei'; margin-bottom: 40px; font-size: 32px;">最新更新 / UPDATES</h2>
            <div class="updates-list">
                <a href="#" class="update-item">
                    <span class="update-title">《第一本书》第十二章：回声</span>
                    <span class="update-meta">MARCH 20, 2026</span>
                </a>
                <a href="#" class="update-item">
                    <span class="update-title">《第二本书》番外：另一种结局</span>
                    <span class="update-meta">FEBRUARY 15, 2026</span>
                </a>
            </div>
        </section>

        <section class="comment-section">
            <h2 class="comment-title">Discussions</h2>
            <div class="comment-placeholder">
                COMMENTS MODULE SYSTEM READY FOR DEPLOYMENT
            </div>
        </section>
    </div>

    <footer style="text-align:center; padding: 80px; opacity: 0.5; font-family: 'Cinzel'; font-size: 11px; color: white;">
        EST. 2026 / RUI & RUIBEET FICTION ARCHIVE
    </footer>

</body>
</html>
