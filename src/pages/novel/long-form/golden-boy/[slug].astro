---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const novelEntries = await getCollection('novel');
  
  // ✨ 关键修改：过滤掉所有在 golden-boy 文件夹下的 md 文件
  // 这样这个旧路由就只处理根目录下的短篇小说（如 suzhouhe, earthquake 等）
  const filteredEntries = novelEntries.filter(entry => !entry.id.startsWith('golden-boy/'));

  return filteredEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
