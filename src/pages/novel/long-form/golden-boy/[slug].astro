---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const novelEntries = await getCollection('novel');
  
  // 🔍 过滤出文件夹名为 golden-boy 的所有 md 文件
  const filtered = novelEntries.filter(entry => entry.id.startsWith('golden-boy/'));

  return filtered.map(entry => {
    // 提取文件名作为 slug (例如 "chapter-1")
    const slugPart = entry.slug.split('/').pop(); 
    
    return {
      params: { slug: slugPart }, 
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
