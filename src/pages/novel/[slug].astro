---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// 1. 告诉 Astro 哪些路径需要生成
export async function getStaticPaths() {
  const novelEntries = await getCollection('novel');
  return novelEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. 获取当前文章的数据
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title} | Rui Fiction</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Noto+Serif+SC:wght@300;500;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        /* 基础设置：深色背景，营造阅读氛围 */
        body { 
            background-color: #1a1a1a; 
            color: #e0e0e0; 
            margin: 0; 
            font-family: 'Noto Serif SC', serif; 
        }

        /* 阅读容器：模仿精装书页 */
        main { 
            max-width: 800px; 
            margin: 0 auto; 
            background: #fff; 
            color: #222; 
            padding: 100px 60px; 
            min-height: 100vh;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }

        /* 导航 */
        .back-nav { 
            margin-bottom: 60px; 
            font-family: 'Playfair Display', serif; 
            font-size: 13px; 
            letter-spacing: 0.2em; 
        }
        .back-nav a { color: #888; text-decoration: none; border-bottom: 1px solid #eee; transition: 0.3s; }
        .back-nav a:hover { color: #0A9C49; border-color: #0A9C49; }

        /* 标题区 */
        header { text-align: center; margin-bottom: 80px; }
        .meta { 
            font-family: 'Playfair Display', serif; 
            font-size: 12px; 
            text-transform: uppercase; 
            letter-spacing: 0.3em; 
            color: #999; 
            margin-bottom: 20px; 
        }
        h1 { 
            font-family: 'ZCOOL XiaoWei', serif; 
            font-size: clamp(32px, 5vw, 52px); 
            line-height: 1.2; 
            color: #000; 
            margin: 0;
        }

        /* 封面图 */
        .cover-wrapper { 
            margin: 60px 0; 
            border: 1px solid #000; 
            padding: 10px; 
            background: #f9f9f9; 
        }
        .cover-img { width: 100%; height: auto; display: block; }

        /* 正文样式：极高行间距，适合长文阅读 */
        .content { 
            font-size: 18px; 
            line-height: 2.2; 
            text-align: justify; 
            hyphens: auto;
        }
        .content :global(p) { margin-bottom: 2.5em; text-indent: 2em; }
        .content :global(p:first-of-type) { text-indent: 0; }
        .content :global(p:first-of-type::first-letter) {
            font-family: 'ZCOOL XiaoWei';
            font-size: 3.5em;
            float: left;
            line-height: 1;
            margin-right: 0.1em;
            color: #0A9C49;
        }

        /* 响应式 */
        @media (max-width: 600px) {
            main { padding: 60px 25px; }
            .content { font-size: 17px; }
        }
    </style>
</head>
<body>
    <main>
        <nav class="back-nav">
            <a href="/novel/short-stories">← BACK TO FICTION</a>
        </nav>

        <header>
            <div class="meta">{entry.data.category} / {entry.data.date}</div>
            <h1>{entry.data.title}</h1>
        </header>

        {entry.data.image && (
            <div class="cover-wrapper">
                <Image 
                    src={entry.data.image} 
                    alt={entry.data.title} 
                    class="cover-img"
                    width={1200}
                    height={800}
                />
            </div>
        )}

        <article class="content">
            <Content />
        </article>

        <footer style="margin-top: 120px; padding-top: 40px; border-top: 1px solid #eee; text-align: center; font-family: 'Playfair Display'; font-size: 12px; color: #bbb; letter-spacing: 0.2em;">
            THE END OF ARCHIVE
        </footer>
    </main>
</body>
</html>
