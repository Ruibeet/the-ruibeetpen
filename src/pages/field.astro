---
const title = "Field Observations";
const subtitle = "Digital Ethnography & Cultural Research";

// 模拟田野报告数据
const fieldReports = [
    { 
        id: "REPORT_001",
        date: "2026.03.10",
        location: "TikTok / Douyin Stream",
        title: "下沉市场的直播审美与情感劳动", 
        enTitle: "Aesthetic & Emotional Labor in Lower-tier Markets",
        summary: "针对近期直播间出现的‘田园怀旧’现象进行的参与式观察。探讨了景观社会中虚构乡村如何完成资本变现...",
        hasImage: true,
        image: "/api/placeholder/600/400"
    },
    { 
        id: "REPORT_002",
        date: "2026.02.15",
        location: "Melbourne Aged Care Center",
        title: "老龄化社会的空间政治：走廊与公共区域", 
        enTitle: "Spatial Politics of Aging: Corridors & Common Areas",
        summary: "在养老院进行的初步空间制图。观察老人如何在被规定的空间内建立临时的社交节点，以及物理边界对心理安全感的影响...",
        hasImage: false
    },
    { 
        id: "REPORT_003",
        date: "2026.01.22",
        location: "Substack / Digital Archive",
        title: "双语写作中的文化翻译与‘解释性负担’", 
        enTitle: "Cultural Translation & Explanatory Burden in Writing",
        summary: "分析在中文社交语境迁移至英文平台时，写作者如何通过文本策略消解或重构文化隔阂...",
        hasImage: true,
        image: "/api/placeholder/600/400"
    }
];
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rui</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg-color: #F3DE16; /* 首页“田野”块的明黄色 */
            --border-color: #000000; 
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Noto Serif SC', serif; 
            background-color: var(--bg-color); 
            color: black; 
            line-height: 1.6;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 60px 40px; }

        /* 1. Header (极致的学术排版感) */
        .page-header { 
            border-bottom: 4px solid black; 
            padding-bottom: 40px; 
            margin-bottom: 60px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }
        .header-left h1 { font-family: 'Playfair Display'; font-size: 60px; line-height: 1; }
        .header-left p { font-family: 'Cinzel'; letter-spacing: 5px; font-size: 12px; margin-top: 15px; font-weight: 700; }
        .header-right { font-family: 'Cinzel'; text-align: right; font-size: 10px; opacity: 0.6; line-height: 2; }

        /* 2. 报告列表 (工整、对称、列表形式) */
        .reports-list { display: flex; flex-direction: column; gap: 0; border-top: 1px solid black; }

        .report-item {
            display: grid;
            grid-template-columns: 200px 1fr 300px; /* ID/日期 | 内容 | 图片(如果有) */
            gap: 40px;
            padding: 40px 0;
            border-bottom: 1px solid black;
            text-decoration: none;
            color: black;
            transition: background 0.3s;
        }
        .report-item:hover { background: rgba(0,0,0,0.03); }

        /* 编号与日期列 */
        .report-meta { font-family: 'Cinzel'; font-size: 12px; display: flex; flex-direction: column; gap: 10px; }
        .report-id { font-weight: 700; background: black; color: var(--bg-color); display: inline-block; padding: 2px 8px; width: fit-content; }

        /* 中间内容列 */
        .report-main-info { display: flex; flex-direction: column; gap: 12px; }
        .report-location { font-family: 'Cinzel'; font-size: 10px; text-transform: uppercase; letter-spacing: 2px; color: #555; }
        .report-title { font-family: 'ZCOOL XiaoWei'; font-size: 28px; line-height: 1.2; }
        .report-en { font-family: 'Cinzel'; font-size: 11px; font-weight: 700; opacity: 0.6; }
        .report-summary { font-size: 14px; opacity: 0.8; text-align: justify; margin-top: 10px; }

        /* 右侧图片列 */
        .report-visual { width: 100%; height: 200px; border: 2px solid black; overflow: hidden; background: white; }
        .report-visual img { width: 100%; height: 100%; object-fit: cover; filter: sepia(20%); }
        .no-image-placeholder { 
            height: 100%; display: flex; align-items: center; justify-content: center; 
            font-family: 'Cinzel'; font-size: 10px; color: #999; border: 1px dashed #999;
        }

        /* 移动端适配 */
        @media (max-width: 900px) {
            .report-item { grid-template-columns: 1fr; gap: 20px; }
            .report-visual { height: 250px; }
            .page-header { flex-direction: column; align-items: flex-start; gap: 20px; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="page-header">
            <div class="header-left">
                <h1>{title}</h1>
                <p>DIGITAL ETHNOGRAPHY ARCHIVE</p>
            </div>
            <div class="header-right">
                SERIAL NO: R-2026-F<br/>
                CLASSIFICATION: OPEN ACCESS<br/>
                RESEARCHER: RUI X. ZHANG
            </div>
        </header>

        <main class="reports-list">
            {fieldReports.map((report) => (
                <a href="#" class="report-item">
                    <div class="report-meta">
                        <span class="report-id">{report.id}</span>
                        <span>{report.date}</span>
                    </div>

                    <div class="report-main-info">
                        <span class="report-location">Location: {report.location}</span>
                        <h2 class="report-title">{report.title}</h2>
                        <span class="report-en">{report.enTitle}</span>
                        <p class="report-summary">{report.summary}</p>
                    </div>

                    <div class="report-visual-wrapper">
                        {report.hasImage ? (
                            <div class="report-visual">
                                <img src={report.image} alt="Observation Data" />
                            </div>
                        ) : (
                            <div class="no-image-placeholder">
                                [ NO VISUAL DATA ATTACHED ]
                            </div>
                        )}
                    </div>
                </a>
            ))}
        </main>

        <footer style="margin-top: 100px; padding: 40px 0; border-top: 1px solid black; display: flex; justify-content: space-between; font-family: 'Cinzel'; font-size: 10px; opacity: 0.6;">
            <span>DATA RECORDED IN 2026</span>
            <span>RUI & RUIBEET OBSERVATORY</span>
        </footer>
    </div>

</body>
</html>
