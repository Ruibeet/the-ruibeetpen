---
// 彻底删掉 getCollection 逻辑，排除所有外部干扰
const title = "Field Observations";
const subtitle = "Digital Ethnography & Cultural Research";

// 手动写死两条数据，确保页面有东西看
const displayReports = [
    { 
        id: "REPORT_001",
        date: "2026.03.24",
        location: "System Diagnostic",
        title: "田野页面路径激活成功", 
        enTitle: "Path Activation Success",
        summary: "如果你看到这个条目，说明 /field 路径已经正式绕过数据库报错上线。这是纯静态渲染模式。",
        hasImage: false
    }
];
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Rui</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@300;700&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
    <style>
        :root { --bg-color: #F3DE16; }
        body { font-family: 'Noto Serif SC', serif; background-color: var(--bg-color); color: black; margin: 0; }
        .container { max-width: 1200px; margin: 0 auto; padding: 60px 40px; }
        .page-header { border-bottom: 4px solid black; padding-bottom: 40px; margin-bottom: 60px; display: flex; justify-content: space-between; align-items: flex-end; }
        .header-left h1 { font-family: 'Playfair Display'; font-size: clamp(40px, 8vw, 60px); margin: 0; }
        .reports-list { border-top: 1px solid black; }
        .report-item { display: grid; grid-template-columns: 200px 1fr 300px; gap: 40px; padding: 40px 0; border-bottom: 1px solid black; text-decoration: none; color: black; }
        .report-id { font-family: 'Cinzel'; font-weight: 700; background: black; color: var(--bg-color); padding: 2px 8px; font-size: 12px; }
        .report-title { font-family: 'ZCOOL XiaoWei'; font-size: 28px; margin: 10px 0; }
        @media (max-width: 900px) { .report-item { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <div class="container">
        <header class="page-header">
            <div class="header-left">
                <h1>{title}</h1>
                <p style="font-family: 'Cinzel'; letter-spacing: 5px; font-size: 12px;">ARCHIVE</p>
            </div>
            <div style="font-family: 'Cinzel'; font-size: 10px; opacity: 0.6; text-align: right;">
                RUI X. ZHANG / FIELD NOTES
            </div>
        </header>

        <main class="reports-list">
            {displayReports.map((report) => (
                <div class="report-item">
                    <div class="report-meta">
                        <span class="report-id">{report.id}</span>
                        <div style="margin-top:10px; font-family: 'Cinzel'; font-size: 12px;">{report.date}</div>
                    </div>
                    <div>
                        <div style="font-family: 'Cinzel'; font-size: 10px; letter-spacing: 2px;">LOCATION: {report.location}</div>
                        <h2 class="report-title">{report.title}</h2>
                        <p style="font-size: 14px; opacity: 0.8;">{report.summary}</p>
                    </div>
                    <div style="border: 1px dashed #999; height: 100px; display: flex; align-items: center; justify-content: center; font-size: 10px; color: #999;">[ DATA RECORD ]</div>
                </div>
            ))}
        </main>
    </div>
</body>
</html>
